#!/bin/bash
# Script para deploy em produção com docker-compose
# Uso: ./bin/docker-compose-up [--build]

set -e

if [ ! -f config/master.key ] && [ -z "${RAILS_MASTER_KEY}" ]; then
  echo "⚠️  RAILS_MASTER_KEY não definida e config/master.key não encontrado."
  echo "   Gerando config/master.key automaticamente..."
  openssl rand -hex 64 > config/master.key
  echo "✅ config/master.key gerado"

  if [ -f config/credentials.yml.enc ]; then
    echo "⚠️  credentials.yml.enc existente pode não ser descriptografável com a nova chave."
    echo "   Removendo — o Rails recriará um arquivo vazio na próxima inicialização."
    rm config/credentials.yml.enc
  fi
fi

BUILD_FLAG=""
if [ "${1:-}" = "--build" ]; then
  BUILD_FLAG="--build"
fi

echo "🚀 Iniciando deploy em produção..."
docker compose -f docker-compose.prod.yml up -d $BUILD_FLAG
echo "✅ KitsuneFinance rodando em http://localhost:13522"
