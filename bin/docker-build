#!/bin/bash
# Script para buildar e iniciar o Kitsune Finance com docker-compose
# Uso: ./bin/docker-build [--prod]

set -e

COMPOSE_FILE="docker-compose.yml"
if [ "${1:-}" = "--prod" ]; then
  COMPOSE_FILE="docker-compose.prod.yml"
fi

echo "🔄 Atualizando repositório..."
git pull

echo "🚀 Buildando e iniciando com docker compose (${COMPOSE_FILE})..."
docker compose -f "$COMPOSE_FILE" up -d --build

echo "✅ KitsuneFinance rodando em http://localhost:13522"
