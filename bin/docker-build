#!/bin/bash
# Script para buildar a imagem Docker do Kitsune Finance

set -e

echo "🔄 Atualizando repositório..."
git pull

echo "🚀 Iniciando build da imagem docker..."
docker build -t kitsune_finance .

echo "✅ Build concluído com sucesso!"
echo "Para executar, utilize: docker run -d --name kitsune_finance -p 13522:80 -v ~/.local/share/KitsuneFinance/db:/rails/db --restart unless-stopped kitsune_finance:latest"
