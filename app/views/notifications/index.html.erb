<div class="max-w-4xl mx-auto py-8">
  <div class="mb-8 flex items-center justify-between">
    <div>
      <h1 class="text-2xl font-bold text-zinc-100">Notificações</h1>
      <p class="text-zinc-500 text-sm">Acompanhe alertas e atualizações do sistema.</p>
    </div>
    <% if @notifications.unread.any? %>
      <%= button_to "Marcar todas como lidas", mark_all_as_read_dashboard_notifications_path, method: :post, class: "text-sm text-indigo-400 hover:text-indigo-300 transition-colors" %>
    <% end %>
  </div>

  <div class="space-y-4">
    <% if @notifications.any? %>
      <% @notifications.each do |notification| %>
        <div class="bg-zinc-900/40 border <%= notification.read? ? 'border-zinc-800/60' : 'border-indigo-500/30 bg-indigo-500/5' %> rounded-2xl p-4 flex gap-4 backdrop-blur-xl transition-all">
          <div class="flex-shrink-0">
            <div class="w-10 h-10 rounded-full flex items-center justify-center <%= notification.notification_type == 'success' ? 'bg-emerald-500/10 text-emerald-400' : 'bg-indigo-500/10 text-indigo-400' %>">
              <% if notification.notification_type == 'success' %>
                <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path d="M5 13l4 4L19 7" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
              <% else %>
                <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
              <% end %>
            </div>
          </div>
          <div class="flex-grow">
            <div class="flex justify-between items-start">
              <h3 class="font-medium text-zinc-100"><%= notification.title %></h3>
              <span class="text-xs text-zinc-500"><%= time_ago_in_words(notification.created_at) %> atrás</span>
            </div>
            <p class="text-sm text-zinc-400 mt-1"><%= notification.message %></p>
            <% if notification.link.present? %>
              <%= link_to "Ver detalhes", notification.link, class: "inline-block mt-2 text-xs font-medium text-indigo-400 hover:text-indigo-300" %>
            <% end %>
          </div>
        </div>
      <% end %>
    <% else %>
      <div class="bg-zinc-900/40 border border-zinc-800/60 rounded-2xl p-12 text-center">
        <div class="w-16 h-16 bg-zinc-800/60 rounded-full flex items-center justify-center mx-auto mb-4 text-zinc-500">
          <svg class="w-8 h-8" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </div>
        <p class="text-zinc-500">Nenhuma notificação por enquanto.</p>
      </div>
    <% end %>
  </div>
</div>
