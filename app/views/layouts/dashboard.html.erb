<!DOCTYPE html>
<html lang="pt-BR">
  <head>
    <title><%= content_for(:title) || "#{@page_title} — Kitsune Finance" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="mobile-web-app-capable" content="yes">
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
    <meta name="application-name" content="Kitsune Finance">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= yield :head %>

    <link rel="manifest" href="/manifest.json">
    <link rel="icon" type="image/svg+xml" href="/icon.svg?v=2">
    <link rel="apple-touch-icon" href="/icon.svg?v=2">
    <link rel="shortcut icon" href="/icon.svg?v=2">

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:ital,opsz,wght@0,14..32,100..900;1,14..32,100..900&display=swap" rel="stylesheet">

    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag "tailwind", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>

    <style>
      .custom-scrollbar::-webkit-scrollbar { width: 4px; }
      .custom-scrollbar::-webkit-scrollbar-track { background: transparent; }
      .custom-scrollbar::-webkit-scrollbar-thumb { background: #3f3f46; border-radius: 4px; }
      .custom-scrollbar::-webkit-scrollbar-thumb:hover { background: #52525b; }

      .sidebar-tooltip { display: none; }

      @media (min-width: 1024px) {
        #sidebar[data-collapsed="true"] { width: 4rem; }
        #sidebar[data-collapsed="true"] .sidebar-label { display: none; }
        #sidebar[data-collapsed="true"] nav > p { display: none; }
        #sidebar[data-collapsed="true"] .sidebar-link { justify-content: center; padding: 0.625rem; margin: 0 auto; width: 2.5rem; }
        #sidebar[data-collapsed="true"] .sidebar-link .sidebar-tooltip {
          display: block;
          opacity: 0;
          pointer-events: none;
          position: fixed;
          left: 5rem;
          background: #27272a;
          border: 1px solid #3f3f46;
          border-radius: 8px;
          padding: 6px 12px;
          white-space: nowrap;
          font-size: 12px;
          color: #e4e4e7;
          z-index: 60;
          transition: opacity 0.15s;
        }
        #sidebar[data-collapsed="true"] .sidebar-link:hover .sidebar-tooltip {
          opacity: 1;
        }
        #sidebar[data-collapsed="true"] .bottom-user-info .user-details { display: none; }
        #sidebar[data-collapsed="true"] .bottom-user-info { justify-content: center; padding: 0.75rem 0; }
        #sidebar[data-collapsed="true"] .sidebar-mobile-close { display: none; }
        #sidebar[data-collapsed="true"] .sidebar-logo-text { display: none; }
        #sidebar[data-collapsed="true"] .sidebar-logo { justify-content: center; }
      }
    </style>
  </head>

  <body class="bg-zinc-950 text-zinc-100 font-[Inter] antialiased" style="font-family: 'Inter', sans-serif;">

    <%# ── MOBILE SIDEBAR OVERLAY ── %>
    <div id="sidebar-overlay"
         class="fixed inset-0 bg-black/60 backdrop-blur-sm z-30 hidden lg:hidden"
         onclick="toggleSidebar()">
    </div>

    <div class="flex h-screen overflow-hidden">

      <%# ══════════════════════════════════════════════════════════ %>
      <%# SIDEBAR %>
      <%# ══════════════════════════════════════════════════════════ %>
      <aside id="sidebar"
             class="fixed lg:relative z-40 flex flex-col w-64 h-full bg-zinc-900/95 border-r border-zinc-800/60
                    backdrop-blur-xl transition-all duration-300 ease-in-out
                    -translate-x-full lg:translate-x-0 shrink-0 overflow-hidden"
             data-collapsed="false">

        <%# Logo / Brand %>
        <div class="flex items-center gap-3 px-5 py-5 border-b border-zinc-800/60 sidebar-logo">
          <div class="flex items-center justify-center w-9 h-9 rounded-xl bg-gradient-to-br from-indigo-500 to-violet-600 shadow-lg shadow-indigo-500/30 shrink-0">
            <svg class="w-5 h-5 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
            </svg>
          </div>
          <div class="sidebar-logo-text">
            <span class="text-base font-bold text-zinc-100 tracking-tight">Kitsune</span>
            <span class="text-base font-bold bg-gradient-to-r from-indigo-400 to-violet-400 bg-clip-text text-transparent"> Finance</span>
          </div>
          <button onclick="toggleSidebar()"
                  class="sidebar-mobile-close lg:hidden ml-auto flex items-center justify-center w-8 h-8 rounded-lg text-zinc-400 hover:text-zinc-100 hover:bg-zinc-800 transition-colors">
            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/></svg>
          </button>
        </div>

        <%# Navigation %>
        <nav class="flex-1 px-3 py-4 space-y-0.5 overflow-y-auto">

          <%# ── Dashboard ── %>
          <p class="sidebar-label px-3 pt-2 pb-1 text-[10px] font-semibold uppercase tracking-widest text-zinc-500">Dashboard</p>

          <%= link_to dashboard_path, title: "Visão Geral",
                class: "sidebar-link group flex items-center gap-3 px-3 py-2.5 rounded-xl text-sm font-medium transition-all duration-150 #{request.path == dashboard_path ? 'bg-indigo-600/20 text-indigo-300 border border-indigo-500/20' : 'text-zinc-400 hover:text-zinc-100 hover:bg-zinc-800/60'}" do %>
            <svg class="w-4.5 h-4.5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.75"><path stroke-linecap="round" stroke-linejoin="round" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/></svg>
            <span class="sidebar-label">Visão Geral</span>
            <span class="sidebar-tooltip">Visão Geral</span>
          <% end %>

          <%# ── Finanças ── %>
          <p class="sidebar-label px-3 pt-4 pb-1 text-[10px] font-semibold uppercase tracking-widest text-zinc-500">Finanças</p>

          <%= link_to dashboard_accounts_path, title: "Contas",
                class: "sidebar-link group flex items-center gap-3 px-3 py-2.5 rounded-xl text-sm font-medium transition-all duration-150 #{request.path == dashboard_accounts_path ? 'bg-indigo-600/20 text-indigo-300 border border-indigo-500/20' : 'text-zinc-400 hover:text-zinc-100 hover:bg-zinc-800/60'}" do %>
            <svg class="w-4.5 h-4.5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.75"><path stroke-linecap="round" stroke-linejoin="round" d="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z"/></svg>
            <span class="sidebar-label">Contas</span>
            <span class="sidebar-tooltip">Contas</span>
          <% end %>

          <%= link_to dashboard_transactions_path, title: "Transações",
                class: "sidebar-link group flex items-center gap-3 px-3 py-2.5 rounded-xl text-sm font-medium transition-all duration-150 #{request.path == dashboard_transactions_path ? 'bg-indigo-600/20 text-indigo-300 border border-indigo-500/20' : 'text-zinc-400 hover:text-zinc-100 hover:bg-zinc-800/60'}" do %>
            <svg class="w-4.5 h-4.5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.75"><path stroke-linecap="round" stroke-linejoin="round" d="M8 7h12m0 0l-4-4m4 4l-4 4m0 6H4m0 0l4 4m-4-4l4-4"/></svg>
            <span class="sidebar-label">Transações</span>
            <span class="sidebar-tooltip">Transações</span>
          <% end %>

          <%= link_to dashboard_categories_path, title: "Categorias",
                class: "sidebar-link group flex items-center gap-3 px-3 py-2.5 rounded-xl text-sm font-medium transition-all duration-150 #{request.path == dashboard_categories_path ? 'bg-indigo-600/20 text-indigo-300 border border-indigo-500/20' : 'text-zinc-400 hover:text-zinc-100 hover:bg-zinc-800/60'}" do %>
            <svg class="w-4.5 h-4.5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.75"><path stroke-linecap="round" stroke-linejoin="round" d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A1.994 1.994 0 013 12V7a4 4 0 014-4z"/></svg>
            <span class="sidebar-label">Categorias</span>
            <span class="sidebar-tooltip">Categorias</span>
          <% end %>

          <%= link_to dashboard_budgets_path, title: "Orçamento",
                class: "sidebar-link group flex items-center gap-3 px-3 py-2.5 rounded-xl text-sm font-medium transition-all duration-150 #{request.path == dashboard_budgets_path ? 'bg-indigo-600/20 text-indigo-300 border border-indigo-500/20' : 'text-zinc-400 hover:text-zinc-100 hover:bg-zinc-800/60'}" do %>
            <svg class="w-4.5 h-4.5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.75"><path stroke-linecap="round" stroke-linejoin="round" d="M9 7h6m0 10v-3m-3 3h.01M9 17h.01M9 14h.01M12 14h.01M15 11h.01M12 11h.01M9 11h.01M7 21h10a2 2 0 002-2V5a2 2 0 00-2-2H7a2 2 0 00-2 2v14a2 2 0 002 2z"/></svg>
            <span class="sidebar-label">Orçamento</span>
            <span class="sidebar-tooltip">Orçamento</span>
          <% end %>

          <%# ── Obrigações ── %>
          <p class="sidebar-label px-3 pt-4 pb-1 text-[10px] font-semibold uppercase tracking-widest text-zinc-500">Obrigações</p>

          <%= link_to dashboard_debts_path, title: "Dívidas",
                class: "sidebar-link group flex items-center gap-3 px-3 py-2.5 rounded-xl text-sm font-medium transition-all duration-150 #{request.path == dashboard_debts_path ? 'bg-indigo-600/20 text-indigo-300 border border-indigo-500/20' : 'text-zinc-400 hover:text-zinc-100 hover:bg-zinc-800/60'}" do %>
            <svg class="w-4.5 h-4.5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.75"><path stroke-linecap="round" stroke-linejoin="round" d="M12 8c1.657 0 3 .895 3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
            <span class="sidebar-label">Dívidas</span>
            <span class="sidebar-tooltip">Dívidas</span>
          <% end %>

          <%= link_to dashboard_bill_reminders_path, title: "Contas a Pagar",
                class: "sidebar-link group flex items-center gap-3 px-3 py-2.5 rounded-xl text-sm font-medium transition-all duration-150 #{request.path == dashboard_bill_reminders_path ? 'bg-indigo-600/20 text-indigo-300 border border-indigo-500/20' : 'text-zinc-400 hover:text-zinc-100 hover:bg-zinc-800/60'}" do %>
            <svg class="w-4.5 h-4.5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.75"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4"/></svg>
            <span class="sidebar-label">Contas a Pagar</span>
            <span class="sidebar-tooltip">Contas a Pagar</span>
          <% end %>

          <%# ── Investimentos ── %>
          <p class="sidebar-label px-3 pt-4 pb-1 text-[10px] font-semibold uppercase tracking-widest text-zinc-500">Investimentos</p>

          <%= link_to dashboard_investments_path, title: "Carteira",
                class: "sidebar-link group flex items-center gap-3 px-3 py-2.5 rounded-xl text-sm font-medium transition-all duration-150 #{current_page?(dashboard_investments_path) || request.path.start_with?('/dashboard/investments') ? 'bg-indigo-600/20 text-indigo-300 border border-indigo-500/20' : 'text-zinc-400 hover:text-zinc-100 hover:bg-zinc-800/60'}" do %>
            <svg class="w-4.5 h-4.5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.75"><path stroke-linecap="round" stroke-linejoin="round" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"/></svg>
            <span class="sidebar-label">Carteira</span>
            <span class="sidebar-tooltip">Carteira</span>
          <% end %>

          <%= link_to dashboard_goals_path, title: "Metas",
                class: "sidebar-link group flex items-center gap-3 px-3 py-2.5 rounded-xl text-sm font-medium transition-all duration-150 #{request.path == dashboard_goals_path ? 'bg-indigo-600/20 text-indigo-300 border border-indigo-500/20' : 'text-zinc-400 hover:text-zinc-100 hover:bg-zinc-800/60'}" do %>
            <svg class="w-4.5 h-4.5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.75"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z"/></svg>
            <span class="sidebar-label">Metas</span>
            <span class="sidebar-tooltip">Metas</span>
          <% end %>

          <%= link_to dashboard_reports_path, title: "Relatórios",
                class: "sidebar-link group flex items-center gap-3 px-3 py-2.5 rounded-xl text-sm font-medium transition-all duration-150 #{request.path == dashboard_reports_path ? 'bg-indigo-600/20 text-indigo-300 border border-indigo-500/20' : 'text-zinc-400 hover:text-zinc-100 hover:bg-zinc-800/60'}" do %>
            <svg class="w-4.5 h-4.5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.75"><path stroke-linecap="round" stroke-linejoin="round" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/></svg>
            <span class="sidebar-label">Relatórios</span>
            <span class="sidebar-tooltip">Relatórios</span>
          <% end %>

          <%# ── Ferramentas ── %>
          <p class="sidebar-label px-3 pt-4 pb-1 text-[10px] font-semibold uppercase tracking-widest text-zinc-500">Ferramentas</p>

          <%= link_to dashboard_health_path, title: "Saúde Financeira",
                class: "sidebar-link group flex items-center gap-3 px-3 py-2.5 rounded-xl text-sm font-medium transition-all duration-150 #{request.path == dashboard_health_path ? 'bg-indigo-600/20 text-indigo-300 border border-indigo-500/20' : 'text-zinc-400 hover:text-zinc-100 hover:bg-zinc-800/60'}" do %>
            <svg class="w-4.5 h-4.5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.75"><path stroke-linecap="round" stroke-linejoin="round" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"/></svg>
            <span class="sidebar-label">Saúde Financeira</span>
            <span class="sidebar-tooltip">Saúde Financeira</span>
          <% end %>

          <%= link_to dashboard_simulation_path, title: "Simulação",
                class: "sidebar-link group flex items-center gap-3 px-3 py-2.5 rounded-xl text-sm font-medium transition-all duration-150 #{request.path == dashboard_simulation_path ? 'bg-indigo-600/20 text-indigo-300 border border-indigo-500/20' : 'text-zinc-400 hover:text-zinc-100 hover:bg-zinc-800/60'}" do %>
            <svg class="w-4.5 h-4.5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.75"><path stroke-linecap="round" stroke-linejoin="round" d="M9 19v2a2 2 0 002 2h2a2 2 0 002-2v-2m0-6v-2a2 2 0 00-2-2h-2a2 2 0 00-2 2v2m6 0a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2v-6a2 2 0 00-2-2h-2z"/></svg>
            <span class="sidebar-label">Simulação</span>
            <span class="sidebar-tooltip">Simulação</span>
          <% end %>

          <%# ── Sistema ── %>
          <p class="sidebar-label px-3 pt-4 pb-1 text-[10px] font-semibold uppercase tracking-widest text-zinc-500">Sistema</p>

          <%= link_to dashboard_backup_path, title: "Backup",
                class: "sidebar-link group flex items-center gap-3 px-3 py-2.5 rounded-xl text-sm font-medium transition-all duration-150 #{request.path == dashboard_backup_path ? 'bg-indigo-600/20 text-indigo-300 border border-indigo-500/20' : 'text-zinc-400 hover:text-zinc-100 hover:bg-zinc-800/60'}" do %>
            <svg class="w-4.5 h-4.5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.75"><path stroke-linecap="round" stroke-linejoin="round" d="M8 7H5a2 2 0 00-2 2v9a2 2 0 002 2h14a2 2 0 002-2V9a2 2 0 00-2-2h-3m-1 4l-3 3m0 0l-3-3m3 3V4"/></svg>
            <span class="sidebar-label">Backup</span>
            <span class="sidebar-tooltip">Backup</span>
          <% end %>

          <%= link_to dashboard_settings_path, title: "Configurações",
                class: "sidebar-link group flex items-center gap-3 px-3 py-2.5 rounded-xl text-sm font-medium transition-all duration-150 #{request.path == dashboard_settings_path ? 'bg-indigo-600/20 text-indigo-300 border border-indigo-500/20' : 'text-zinc-400 hover:text-zinc-100 hover:bg-zinc-800/60'}" do %>
            <svg class="w-4.5 h-4.5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.75"><path stroke-linecap="round" stroke-linejoin="round" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"/><path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
            <span class="sidebar-label">Configurações</span>
            <span class="sidebar-tooltip">Configurações</span>
          <% end %>

        </nav>

        <%# Bottom: User Info %>
        <div class="border-t border-zinc-800/60 bottom-user-info">
          <div class="flex items-center gap-3 px-3 py-3">
            <div class="flex items-center justify-center w-8 h-8 rounded-full bg-gradient-to-br from-indigo-500 to-violet-600 text-white text-xs font-bold shrink-0">
              <%= current_user.email.first.upcase %>
            </div>
            <div class="user-details flex-1 min-w-0">
              <p class="text-xs font-semibold text-zinc-200 truncate"><%= current_user.email.split('@').first.capitalize %></p>
              <p class="text-[10px] text-zinc-500 truncate"><%= current_user.email %></p>
            </div>
          </div>
        </div>
      </aside>

      <%# ══════════════════════════════════════════════════════════ %>
      <%# MAIN AREA (Navbar + Content) %>
      <%# ══════════════════════════════════════════════════════════ %>
      <div class="flex flex-col flex-1 min-w-0 overflow-hidden">

        <%# ── TOPBAR (Navbar) ── %>
        <header class="flex items-center justify-between h-16 px-4 lg:px-6 bg-zinc-900/80 border-b border-zinc-800/60 backdrop-blur-xl shrink-0 z-20">

          <%# Left: Mobile hamburger + Page title %>
          <div class="flex items-center gap-2">
            <button id="sidebar-toggle"
                    onclick="toggleSidebar()"
                    class="flex items-center justify-center w-9 h-9 rounded-lg text-zinc-400 hover:text-zinc-100 hover:bg-zinc-800 transition-colors"
                    aria-label="Toggle sidebar">
              <svg class="w-5 h-5 lg:hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16"/>
              </svg>
              <svg class="w-5 h-5 hidden lg:block sidebar-collapse-icon" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M11 19l-7-7 7-7m8 14l-7-7 7-7"/>
              </svg>
            </button>
            <div>
              <h1 class="text-base font-semibold text-zinc-100"><%= @page_title %></h1>
              <p class="text-xs text-zinc-500 hidden sm:block">
                <%= l(Date.today, format: "%A, %d de %B de %Y") rescue Date.today.strftime("%d/%m/%Y") %>
              </p>
            </div>
          </div>

          <%# Right: Actions %>
          <div class="flex items-center gap-2">

            <%# Search %>
            <button id="navbar-search-btn"
                    onclick="Kitsune?.openSearchModal()"
                    class="flex items-center justify-center w-9 h-9 rounded-lg text-zinc-400 hover:text-zinc-100 hover:bg-zinc-800 transition-colors"
                    aria-label="Buscar"
                    title="Buscar (/)">
              <svg class="w-4.5 h-4.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.75">
                <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
              </svg>
            </button>

            <%# Theme Toggle %>
            <button id="theme-toggle-btn"
                    class="flex items-center justify-center w-9 h-9 rounded-lg text-zinc-400 hover:text-zinc-100 hover:bg-zinc-800 transition-colors"
                    aria-label="Alternar tema">
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z"/>
              </svg>
            </button>

            <%# Notification bell %>
            <%= link_to dashboard_notifications_path, class: "relative flex items-center justify-center w-9 h-9 rounded-lg text-zinc-400 hover:text-zinc-100 hover:bg-zinc-800 transition-colors", aria: { label: "Notificações" } do %>
              <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.75">
                <path stroke-linecap="round" stroke-linejoin="round" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9"/>
              </svg>
              <% if current_user.notifications.unread.any? %>
                <span class="absolute top-1 right-1 flex h-4 w-4">
                  <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-indigo-400 opacity-75"></span>
                  <span class="relative inline-flex items-center justify-center rounded-full h-4 w-4 bg-indigo-500 text-[10px] font-bold text-white ring-2 ring-zinc-900">
                    <%= [current_user.notifications.unread.count, 9].min %>
                  </span>
                </span>
              <% end %>
            <% end %>


            <%# Logout %>
            <%= button_to destroy_user_session_path, method: :delete,
                  class: "flex items-center justify-center w-9 h-9 rounded-lg text-zinc-500 hover:text-red-400 hover:bg-red-500/10 transition-colors",
                  title: "Sair",
                  form: { "data-turbo": false } do %>
              <svg class="w-4.5 h-4.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.75">
                <path stroke-linecap="round" stroke-linejoin="round" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"/>
              </svg>
            <% end %>
          </div>
        </header>

        <%# ── Flash Messages ── %>
        <div class="fixed top-4 right-4 z-50 flex flex-col gap-2 w-80 pointer-events-none">
          <% if notice %>
            <p class="animate-fade-in-up bg-emerald-500/10 text-emerald-400 border border-emerald-500/20 px-5 py-3 rounded-xl shadow-lg backdrop-blur-md pointer-events-auto text-sm">
              <%= notice %>
            </p>
          <% end %>
          <% if alert %>
            <p class="animate-fade-in-up bg-red-500/10 text-red-400 border border-red-500/20 px-5 py-3 rounded-xl shadow-lg backdrop-blur-md pointer-events-auto text-sm">
              <%= alert %>
            </p>
          <% end %>
        </div>

        <%# ── SCROLLABLE CONTENT AREA ── %>
        <main class="flex-1 overflow-y-auto bg-zinc-950 scroll-smooth">
          <div class="w-full px-4 lg:px-8 xl:px-10 py-8 animate-fade-in">
            <%= yield %>
          </div>
        </main>
      </div>
    </div>

    <script>
      function toggleSidebar() {
        const sidebar = document.getElementById('sidebar');
        const overlay = document.getElementById('sidebar-overlay');
        const isMobile = window.innerWidth < 1024;

        if (isMobile) {
          const isOpen = !sidebar.classList.contains('-translate-x-full');
          sidebar.classList.toggle('-translate-x-full');
          overlay.classList.toggle('hidden');
          document.body.style.overflow = isOpen ? '' : 'hidden';
        } else {
          const isCollapsed = sidebar.dataset.collapsed === 'true';
          sidebar.dataset.collapsed = isCollapsed ? 'false' : 'true';
          document.querySelector('.sidebar-collapse-icon')?.classList.toggle('rotate-180');
          localStorage.setItem('kitsune_sidebar_collapsed', sidebar.dataset.collapsed);
        }
      }

      (function() {
        if (window.innerWidth >= 1024 && localStorage.getItem('kitsune_sidebar_collapsed') === 'true') {
          const sidebar = document.getElementById('sidebar');
          sidebar.dataset.collapsed = 'true';
          document.querySelector('.sidebar-collapse-icon')?.classList.add('rotate-180');
        }
      })();
    </script>
    <script>
      document.addEventListener('keydown', function(e) {
        if (e.key === 'Escape') {
          const sidebar = document.getElementById('sidebar');
          const overlay = document.getElementById('sidebar-overlay');
          if (window.innerWidth < 1024 && !sidebar.classList.contains('-translate-x-full')) {
            sidebar.classList.add('-translate-x-full');
            overlay.classList.add('hidden');
            document.body.style.overflow = '';
          }
        }
      });
    </script>
  </body>
</html>
