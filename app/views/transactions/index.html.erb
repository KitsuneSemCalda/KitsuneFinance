<div class="flex flex-col md:flex-row justify-between items-start md:items-center mb-6 gap-4">
  <div>
    <h2 class="text-2xl font-bold text-zinc-100">Transações</h2>
    <p class="text-zinc-500 text-sm">Histórico completo de entradas e saídas.</p>
  </div>
  <div class="flex flex-wrap items-center gap-3">
    <div class="flex items-center bg-zinc-900 border border-zinc-800 rounded-xl overflow-hidden p-1 mr-2">
      <%= link_to dashboard_transactions_path(format: :csv), class: "p-2 text-zinc-500 hover:text-indigo-400 hover:bg-zinc-800 transition-all rounded-lg", title: "Exportar CSV" do %>
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5l5 5v11a2 2 0 01-2 2z" stroke-width="2"/></svg>
      <% end %>
      <%= link_to dashboard_transactions_path(format: :xlsx), class: "p-2 text-zinc-500 hover:text-emerald-400 hover:bg-zinc-800 transition-all rounded-lg", title: "Exportar Excel" do %>
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path d="M9 17v-2m3 2v-4m3 4v-6m2 10H7a2 2 0 01-2-2V5a2 2 0 012-2h5l5 5v11a2 2 0 01-2 2z" stroke-width="2"/></svg>
      <% end %>
    </div>
    <%= link_to import_dashboard_transactions_path, class: "bg-zinc-800 hover:bg-zinc-700 text-zinc-300 font-bold py-2.5 px-5 rounded-xl transition-all border border-zinc-700 flex items-center gap-2 text-xs uppercase tracking-widest" do %>
      <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-8l-4-4m0 0L8 8m4-4v12" stroke-width="2"/></svg>
      Importar
    <% end %>
    <%= link_to new_dashboard_transaction_path, class: "bg-indigo-600 hover:bg-indigo-500 text-white font-bold py-2.5 px-5 rounded-xl transition-all shadow-lg shadow-indigo-500/25 flex items-center gap-2 text-xs uppercase tracking-widest" do %>
      <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path d="M12 4v16m8-8H4" stroke-width="2"/></svg>
      Nova Transação
    <% end %>
  </div>
</div>

<%# ── SEARCH & FILTERS ── %>
<div class="mb-4 bg-zinc-900/40 border border-zinc-800/60 rounded-2xl p-4 backdrop-blur-xl">
  <div class="flex flex-col lg:flex-row gap-3">
    <div class="flex-1 relative">
      <svg class="absolute left-4 top-1/2 -translate-y-1/2 w-4 h-4 text-zinc-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
      </svg>
      <input type="text" id="tx-search" placeholder="Buscar por descrição... (atalho: /)"
             class="w-full bg-zinc-950 border border-zinc-800 rounded-xl pl-10 pr-4 py-2.5 text-sm text-zinc-100 focus:border-indigo-500 outline-none transition-all placeholder:text-zinc-600">
    </div>
    <div class="flex flex-wrap gap-2">
      <select id="tx-filter-type" class="bg-zinc-950 border border-zinc-800 rounded-xl px-3 py-2.5 text-xs text-zinc-100 focus:border-indigo-500 outline-none transition-all">
        <option value="">Todas</option>
        <option value="expense">Despesas</option>
        <option value="income">Receitas</option>
        <option value="transfer">Transferências</option>
      </select>
      <select id="tx-filter-category" class="bg-zinc-950 border border-zinc-800 rounded-xl px-3 py-2.5 text-xs text-zinc-100 focus:border-indigo-500 outline-none transition-all">
        <option value="">Categorias</option>
        <% current_user.categories.order(:name).each do |cat| %>
          <option value="<%= cat.id %>"><%= cat.icon %> <%= cat.name %></option>
        <% end %>
      </select>
      <select id="tx-filter-account" class="bg-zinc-950 border border-zinc-800 rounded-xl px-3 py-2.5 text-xs text-zinc-100 focus:border-indigo-500 outline-none transition-all">
        <option value="">Contas</option>
        <% current_user.accounts.order(:name).each do |acc| %>
          <option value="<%= acc.id %>"><%= acc.name %></option>
        <% end %>
      </select>
      <select id="tx-date-range" class="bg-zinc-950 border border-zinc-800 rounded-xl px-3 py-2.5 text-xs text-zinc-100 focus:border-indigo-500 outline-none transition-all">
        <option value="all">Período</option>
        <option value="today">Hoje</option>
        <option value="week">Esta semana</option>
        <option value="month">Este mês</option>
        <option value="custom">Personalizado</option>
      </select>
      <button id="tx-filter-reset" class="text-zinc-500 hover:text-zinc-300 text-xs font-bold px-3 py-2.5 rounded-xl hover:bg-zinc-800 transition-all">
        Limpar
      </button>
    </div>
  </div>
  <div id="tx-date-custom" class="hidden mt-3 flex gap-3">
    <input type="date" id="tx-date-from" class="bg-zinc-950 border border-zinc-800 rounded-xl px-4 py-2 text-xs text-zinc-100 focus:border-indigo-500 outline-none transition-all">
    <span class="text-zinc-600 text-xs self-center">até</span>
    <input type="date" id="tx-date-to" class="bg-zinc-950 border border-zinc-800 rounded-xl px-4 py-2 text-xs text-zinc-100 focus:border-indigo-500 outline-none transition-all">
  </div>
</div>

<%# ── TRANSACTION LIST (Hybrid View) ── %>
<div class="bg-zinc-900/40 border border-zinc-800/60 rounded-3xl overflow-hidden backdrop-blur-xl">
  
  <%# Desktop Table %>
  <div class="hidden lg:block overflow-x-auto tx-table-wrapper">
    <table class="w-full text-left border-collapse">
      <thead>
        <tr class="bg-zinc-900/80 border-b border-zinc-800/60">
          <th class="px-6 py-4 text-[10px] font-bold text-zinc-500 uppercase tracking-[0.2em]">Data</th>
          <th class="px-6 py-4 text-[10px] font-bold text-zinc-500 uppercase tracking-[0.2em]">Descrição</th>
          <th class="px-6 py-4 text-[10px] font-bold text-zinc-500 uppercase tracking-[0.2em]">Categoria</th>
          <th class="px-6 py-4 text-[10px] font-bold text-zinc-500 uppercase tracking-[0.2em]">Conta</th>
          <th class="px-6 py-4 text-[10px] font-bold text-zinc-500 uppercase tracking-[0.2em] text-right">Valor</th>
          <th class="px-6 py-4 text-[10px] font-bold text-zinc-500 uppercase tracking-[0.2em] text-center">Ações</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-zinc-800/60">
        <% @transactions.each_with_index do |tx, index| %>
          <tr class="tx-row hover:bg-zinc-800/40 transition-all group animate-fade-in-up"
              style="animation-delay: <%= [index * 0.03, 0.4].min %>s"
              data-tx-id="<%= tx.id %>"
              data-description="<%= tx.description.downcase %>"
              data-type="<%= tx.transaction_type %>"
              data-category="<%= tx.category_id %>"
              data-account="<%= tx.account_id %>"
              data-date="<%= tx.date %>">
            <td class="px-6 py-5 text-xs font-bold text-zinc-500 tabular-nums">
              <%= tx.date.strftime("%d %b, %Y") %>
            </td>
            <td class="px-6 py-5">
              <div class="flex items-center gap-3">
                <% if tx.goal_id.present? %>
                  <div class="w-6 h-6 rounded-md bg-indigo-500/10 flex items-center justify-center text-indigo-400" title="Vinculada a uma meta">
                    <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" stroke-width="2.5"/></svg>
                  </div>
                <% end %>
                <p class="text-sm font-bold text-zinc-100 group-hover:text-white transition-colors truncate max-w-[300px]"><%= tx.description %></p>
              </div>
            </td>
            <td class="px-6 py-5">
              <% cat_color = tx.category&.color || 'zinc' %>
              <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-[10px] font-black uppercase tracking-wider bg-<%= cat_color %>-500/10 text-<%= cat_color %>-400 border border-<%= cat_color %>-500/20">
                <span><%= tx.category&.icon || '📌' %></span>
                <%= tx.category&.name || "Sem categoria" %>
              </span>
            </td>
            <td class="px-6 py-5 whitespace-nowrap">
              <div class="flex items-center gap-2">
                <div class="w-1.5 h-1.5 rounded-full bg-<%= tx.account.color %>-500"></div>
                <span class="text-xs font-bold text-zinc-400"><%= tx.account.name %></span>
              </div>
            </td>
            <td class="px-6 py-5 text-right whitespace-nowrap">
              <span class="text-sm font-black tabular-nums tracking-tight <%= tx.transaction_type == 'income' ? 'text-emerald-400' : (tx.transaction_type == 'transfer' ? 'text-sky-400' : 'text-red-400') %>">
                <%= tx.transaction_type == 'income' ? '+' : (tx.transaction_type == 'transfer' ? '⇄' : '—') %>
                <%= number_to_currency(tx.amount.abs / 100.0) %>
              </span>
            </td>
            <td class="px-6 py-5 text-center">
              <div class="flex justify-center gap-1 opacity-0 group-hover:opacity-100 transition-opacity">
                <button class="tx-duplicate-btn p-2 text-zinc-500 hover:text-indigo-400 bg-zinc-800/40 hover:bg-zinc-800 rounded-xl transition-all" title="Duplicar transação">
                  <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z"/>
                  </svg>
                </button>
                <%= link_to edit_dashboard_transaction_path(tx), class: "p-2 text-zinc-500 hover:text-zinc-100 bg-zinc-800/40 hover:bg-zinc-800 rounded-xl transition-all" do %>
                  <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" stroke-width="2"/></svg>
                <% end %>
              </div>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>

  <%# Mobile Cards %>
  <div class="lg:hidden grid grid-cols-1 gap-4 p-4 tx-mobile-wrapper">
    <% @transactions.each do |tx| %>
      <div class="tx-mobile-card bg-zinc-950/40 border border-zinc-800/80 rounded-2xl p-5 space-y-4"
           data-tx-id="<%= tx.id %>"
           data-description="<%= tx.description.downcase %>"
           data-type="<%= tx.transaction_type %>"
           data-category="<%= tx.category_id %>"
           data-account="<%= tx.account_id %>"
           data-date="<%= tx.date %>">
        <div class="flex items-start justify-between">
          <div class="flex items-center gap-3">
            <div class="w-10 h-10 rounded-xl bg-zinc-800 flex items-center justify-center text-xl">
              <%= tx.category&.icon || '📌' %>
            </div>
            <div class="min-w-0">
              <p class="text-sm font-bold text-zinc-100 truncate max-w-[150px]"><%= tx.description %></p>
              <p class="text-[10px] text-zinc-500 font-bold uppercase tracking-widest"><%= tx.date.strftime("%d de %b") %></p>
            </div>
          </div>
          <div class="text-right">
            <p class="text-base font-black tabular-nums tracking-tight <%= tx.transaction_type == 'income' ? 'text-emerald-400' : 'text-red-400' %>">
              <%= tx.transaction_type == 'income' ? '+' : '—' %>
              <%= number_to_currency(tx.amount.abs / 100.0) %>
            </p>
            <p class="text-[9px] font-bold text-zinc-600 uppercase tracking-tighter mt-0.5"><%= tx.account.name %></p>
          </div>
        </div>
        <div class="flex items-center justify-between pt-3 border-t border-zinc-800/40">
          <span class="text-[10px] font-black uppercase tracking-widest text-<%= tx.category&.color || 'zinc' %>-400/80">
            <%= tx.category&.name || "Geral" %>
          </span>
          <div class="flex gap-2">
            <button class="tx-duplicate-btn text-[10px] font-bold text-indigo-400 uppercase tracking-widest" data-tx-id="<%= tx.id %>">Duplicar</button>
            <%= link_to "Editar", edit_dashboard_transaction_path(tx), class: "text-[10px] font-bold text-zinc-400 uppercase tracking-widest" %>
          </div>
        </div>
      </div>
    <% end %>
  </div>

  <% if @transactions.empty? %>
    <div class="flex flex-col items-center justify-center py-20 text-center">
      <div class="w-16 h-16 bg-zinc-800/40 rounded-3xl flex items-center justify-center mb-6">
        <svg class="w-8 h-8 text-zinc-600" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path d="M8 7h12m0 0l-4-4m4 4l-4 4m0 6H4m0 0l4 4m-4-4l4-4" stroke-width="2"/></svg>
      </div>
      <h3 class="text-lg font-bold text-zinc-300">Sem transações</h3>
      <p class="text-zinc-500 text-sm mt-1">Clique em "Nova Transação" ou "Importar" para começar.</p>
    </div>
  <% end %>
</div>
