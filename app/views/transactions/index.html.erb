<div class="flex justify-between items-center mb-8">
  <div>
    <h2 class="text-2xl font-bold text-zinc-100">Transações</h2>
    <p class="text-zinc-500 text-sm">Histórico completo de entradas e saídas.</p>
  </div>
  <div class="flex gap-3">
    <%= link_to import_dashboard_transactions_path, class: "bg-zinc-800 hover:bg-zinc-700 text-zinc-300 font-medium py-2 px-4 rounded-xl transition-all border border-zinc-700 flex items-center gap-2" do %>
      <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-8l-4-4m0 0L8 8m4-4v12" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
      Importar
    <% end %>
    <%= link_to new_dashboard_transaction_path, class: "bg-indigo-600 hover:bg-indigo-500 text-white font-medium py-2 px-4 rounded-xl transition-all shadow-lg shadow-indigo-500/25 flex items-center gap-2" do %>
      <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path d="M12 4v16m8-8H4" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
      Nova Transação
    <% end %>
  </div>
</div>

<div class="bg-zinc-900/40 border border-zinc-800/60 rounded-2xl overflow-hidden backdrop-blur-xl">
  <div class="overflow-x-auto">
    <table class="w-full text-left border-collapse">
      <thead>
        <tr class="bg-zinc-900/60 border-b border-zinc-800/60">
          <th class="px-6 py-4 text-xs font-semibold text-zinc-500 uppercase tracking-wider whitespace-nowrap">Data</th>
          <th class="px-6 py-4 text-xs font-semibold text-zinc-500 uppercase tracking-wider whitespace-nowrap">Descrição</th>
          <th class="px-6 py-4 text-xs font-semibold text-zinc-500 uppercase tracking-wider whitespace-nowrap">Categoria</th>
          <th class="px-6 py-4 text-xs font-semibold text-zinc-500 uppercase tracking-wider whitespace-nowrap">Conta</th>
          <th class="px-6 py-4 text-xs font-semibold text-zinc-500 uppercase tracking-wider text-right whitespace-nowrap">Valor</th>
          <th class="px-6 py-4 text-xs font-semibold text-zinc-500 uppercase tracking-wider text-center whitespace-nowrap">Ações</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-zinc-800/60">
        <% @transactions.each_with_index do |tx, index| %>
          <tr class="hover:bg-zinc-800/40 transition-colors animate-fade-in-up" style="animation-delay: <%= [index * 0.05, 0.5].min %>s">
            <td class="px-6 py-4 text-sm text-zinc-400 whitespace-nowrap">
              <%= tx.date.strftime("%d/%m/%Y") %>
            </td>
            <td class="px-6 py-4 min-w-[200px]">
              <p class="text-sm font-medium text-zinc-100"><%= tx.description %></p>
            </td>
            <td class="px-6 py-4 whitespace-nowrap">
              <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-xs font-medium bg-<%= tx.category&.color || 'zinc' %>-500/10 text-<%= tx.category&.color || 'zinc' %>-400 border border-<%= tx.category&.color || 'zinc' %>-500/20">
                <span><%= tx.category&.icon %></span>
                <%= tx.category&.name || "Sem categoria" %>
              </span>
            </td>
            <td class="px-6 py-4 text-sm text-zinc-400 whitespace-nowrap">
              <%= tx.account.name %>
            </td>
            <td class="px-6 py-4 text-right whitespace-nowrap">
              <span class="text-sm font-bold <%= tx.transaction_type == 'income' ? 'text-emerald-400' : 'text-red-400' %>">
                <%= tx.transaction_type == 'income' ? '+' : '-' %>
                <%= number_to_currency(tx.amount.abs, unit: "R$ ", separator: ",", delimiter: ".") %>
              </span>
            </td>
            <td class="px-6 py-4 text-center whitespace-nowrap">
               <div class="flex justify-center gap-2">
                <%= link_to edit_dashboard_transaction_path(tx), class: "p-1 text-zinc-500 hover:text-zinc-100 transition-colors" do %>
                  <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
                <% end %>
                <%= button_to dashboard_transaction_path(tx), method: :delete, class: "p-1 text-zinc-500 hover:text-red-400 transition-colors", data: { turbo_confirm: "Tem certeza?" } do %>
                  <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
                <% end %>
              </div>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>

  
  <% if @transactions.empty? %>
    <div class="px-6 py-12 text-center">
      <p class="text-zinc-500">Nenhuma transação encontrada.</p>
    </div>
  <% end %>
</div>
