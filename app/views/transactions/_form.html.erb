<div class="max-w-2xl mx-auto">
  <div class="mb-8">
    <h2 class="text-2xl font-bold text-zinc-100"><%= @page_title %></h2>
    <p class="text-zinc-500 text-sm">Registre suas movimentações financeiras com precisão.</p>
  </div>

  <%= form_with model: [:dashboard, @transaction], class: "space-y-6" do |f| %>
    
    <%# ── AMOUNT & TYPE (The most important) ── %>
    <div class="bg-zinc-900/60 border border-zinc-800/60 rounded-3xl p-8 shadow-2xl space-y-8 relative overflow-hidden">
      <div class="absolute top-0 right-0 p-4 opacity-5 pointer-events-none">
        <svg class="w-32 h-32 text-indigo-500" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z" stroke-width="2"/></svg>
      </div>

      <div class="space-y-3 relative z-10">
        <label class="text-[10px] font-bold text-zinc-500 uppercase tracking-widest ml-1">Tipo de Transação</label>
        <div class="flex bg-zinc-950 p-1 rounded-2xl border border-zinc-800">
          <% [["Despesa", "expense"], ["Receita", "income"], ["Transferência", "transfer"]].each do |label, val| %>
            <label class="flex-1 cursor-pointer">
              <%= f.radio_button :transaction_type, val, class: "peer sr-only" %>
              <div class="py-3 text-center text-xs font-bold uppercase tracking-widest text-zinc-500 rounded-xl peer-checked:bg-zinc-800 peer-checked:text-zinc-100 transition-all">
                <%= label %>
              </div>
            </label>
          <% end %>
        </div>
      </div>

      <div class="space-y-2 relative z-10">
        <%= f.label :amount, "Valor da Transação (R$)", class: "text-[10px] font-bold text-zinc-500 uppercase tracking-widest ml-1" %>
        <div class="relative">
          <span class="absolute left-5 top-1/2 -translate-y-1/2 text-2xl font-black text-zinc-600">R$</span>
          <%= f.number_field :amount, step: 0.01, value: (@transaction.amount.abs.to_f / 100), class: "w-full bg-zinc-950 border border-zinc-800 rounded-2xl pl-16 pr-5 py-6 text-zinc-100 text-4xl font-black focus:border-indigo-500 focus:ring-4 focus:ring-indigo-500/10 outline-none transition-all tabular-nums placeholder:text-zinc-800", required: true, placeholder: "0,00" %>
        </div>
      </div>
    </div>

    <%# ── DETAILS ── %>
    <div class="bg-zinc-900/40 border border-zinc-800/60 rounded-3xl p-8 space-y-8">
      
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
        <div class="space-y-2">
          <%= f.label :date, "Data", class: "text-[10px] font-bold text-zinc-500 uppercase tracking-widest ml-1" %>
          <%= f.date_field :date, class: "w-full bg-zinc-950 border border-zinc-800 rounded-2xl px-5 py-4 text-zinc-100 font-bold focus:border-indigo-500 outline-none transition-all" %>
        </div>
        <div class="space-y-2">
          <%= f.label :account_id, "Conta Origem/Destino", class: "text-[10px] font-bold text-zinc-500 uppercase tracking-widest ml-1" %>
          <%= f.collection_select :account_id, current_user.accounts, :id, :name, { prompt: "Selecione a conta" }, class: "w-full bg-zinc-950 border border-zinc-800 rounded-2xl px-5 py-4 text-zinc-100 font-bold focus:border-indigo-500 outline-none transition-all" %>
        </div>
      </div>

      <div id="destination-account-field" class="hidden space-y-2">
        <%= f.label :destination_account_id, "Conta Destino", class: "text-[10px] font-bold text-zinc-500 uppercase tracking-widest ml-1" %>
        <%= f.collection_select :destination_account_id, current_user.accounts, :id, :name, { prompt: "Selecione a conta destino" }, class: "w-full bg-zinc-950 border border-zinc-800 rounded-2xl px-5 py-4 text-zinc-100 font-bold focus:border-indigo-500 outline-none transition-all" %>
      </div>

      <div class="space-y-2">
        <%= f.label :description, "Descrição / Estabelecimento", class: "text-[10px] font-bold text-zinc-500 uppercase tracking-widest ml-1" %>
        <%= f.text_field :description, placeholder: "Ex: Supermercado, Aluguel, Almoço...", class: "w-full bg-zinc-950 border border-zinc-800 rounded-2xl px-5 py-4 text-zinc-100 font-bold focus:border-indigo-500 outline-none transition-all placeholder:text-zinc-700", required: true %>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
        <div class="space-y-2">
          <%= f.label :category_id, "Categoria", class: "text-[10px] font-bold text-zinc-500 uppercase tracking-widest ml-1" %>
          <%= f.collection_select :category_id, current_user.categories, :id, :name, { prompt: "Selecione a categoria" }, class: "w-full bg-zinc-950 border border-zinc-800 rounded-2xl px-5 py-4 text-zinc-100 font-bold focus:border-indigo-500 outline-none transition-all" %>
        </div>
        <div class="space-y-2">
          <%= f.label :goal_id, "Vincular à Meta (Opcional)", class: "text-[10px] font-bold text-zinc-500 uppercase tracking-widest ml-1" %>
          <%= f.collection_select :goal_id, current_user.goals.active, :id, :name, { include_blank: "Nenhuma" }, class: "w-full bg-zinc-950 border border-zinc-800 rounded-2xl px-5 py-4 text-zinc-100 font-bold focus:border-indigo-500 outline-none transition-all" %>
        </div>
      </div>

      <div class="space-y-2">
        <%= f.label :notes, "Notas e Observações", class: "text-[10px] font-bold text-zinc-500 uppercase tracking-widest ml-1" %>
        <%= f.text_area :notes, rows: 3, placeholder: "Detalhes adicionais...", class: "w-full bg-zinc-950 border border-zinc-800 rounded-2xl px-5 py-4 text-zinc-200 text-sm focus:border-indigo-500 outline-none transition-all placeholder:text-zinc-700" %>
      </div>

      <div class="space-y-2">
        <%= f.label :receipt, "Comprovante (Foto)", class: "text-[10px] font-bold text-zinc-500 uppercase tracking-widest ml-1" %>
        <%= f.file_field :receipt, accept: "image/*", capture: "environment", class: "w-full bg-zinc-950 border border-zinc-800 rounded-2xl px-5 py-4 text-zinc-200 text-sm focus:border-indigo-500 outline-none transition-all file:mr-4 file:py-2 file:px-4 file:rounded-xl file:border-0 file:text-xs file:font-bold file:bg-indigo-500/10 file:text-indigo-400 hover:file:bg-indigo-500/20" %>
        <div id="receipt-preview" class="mt-2 <%= 'hidden' unless @transaction.receipt.attached? %>">
          <% if @transaction.receipt.attached? %>
            <%= image_tag @transaction.receipt, class: "max-h-32 rounded-xl border border-zinc-700" %>
          <% end %>
        </div>
      </div>
    </div>

    <%# ── ACTIONS ── %>
    <div class="flex flex-col sm:flex-row gap-4 pt-4">
      <%= link_to "Descartar", dashboard_transactions_path, class: "flex-1 text-center bg-zinc-900 hover:bg-zinc-800 text-zinc-500 font-bold py-4 rounded-2xl border border-zinc-800 transition-all" %>
      <%= f.submit "Salvar Transação", class: "flex-1 bg-indigo-600 hover:bg-indigo-500 text-white font-bold py-4 rounded-2xl transition-all shadow-xl shadow-indigo-500/25 cursor-pointer" %>
    </div>
    
    <% if @transaction.persisted? %>
      <div class="pt-8 border-t border-zinc-800/60 mt-8 flex justify-center">
        <%= button_to dashboard_transaction_path(@transaction), method: :delete, class: "text-red-500/60 hover:text-red-400 text-[10px] font-bold uppercase tracking-[0.2em] transition-colors", data: { turbo_confirm: "Excluir esta transação permanentemente? O saldo da conta será ajustado automaticamente." } do %>
          Excluir Registro
        <% end %>
      </div>
    <% end %>

  <% end %>
</div>
