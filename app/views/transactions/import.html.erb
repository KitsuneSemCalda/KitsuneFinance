<div class="max-w-2xl mx-auto">
  <div class="mb-8">
    <h2 class="text-2xl font-bold text-zinc-100">Importar Transações</h2>
    <p class="text-zinc-500 text-sm">Envie arquivos OFX ou CSV para automatizar seus registros.</p>
  </div>

  <%= form_with url: do_import_dashboard_transactions_path, local: true, multipart: true, class: "space-y-6" do |f| %>
    <div class="bg-zinc-900/60 border border-zinc-800/60 rounded-3xl p-8 shadow-2xl space-y-8">
      <div class="space-y-2">
        <%= f.label :account_id, "Conta de Destino", class: "text-[10px] font-bold text-zinc-500 uppercase tracking-widest ml-1" %>
        <%= f.select :account_id, options_from_collection_for_select(@accounts, :id, :name), {}, class: "w-full bg-zinc-950 border border-zinc-800 rounded-2xl px-5 py-4 text-zinc-100 font-bold focus:border-indigo-500 outline-none transition-all" %>
      </div>

      <div class="space-y-2">
        <%= f.label :file, "Arquivo (OFX ou CSV)", class: "text-[10px] font-bold text-zinc-500 uppercase tracking-widest ml-1" %>
        <div class="mt-1 flex justify-center px-6 pt-8 pb-8 border-2 border-zinc-800 border-dashed rounded-2xl bg-zinc-950/50 hover:border-indigo-500/50 transition-colors">
          <div class="space-y-3 text-center">
            <svg class="mx-auto h-12 w-12 text-zinc-600" stroke="currentColor" fill="none" viewBox="0 0 48 48">
              <path d="M28 8H12a4 4 0 00-4 4v20m32-12v8m0 0v8a4 4 0 01-4 4H12a4 4 0 01-4-4v-4m32-4l-3.172-3.172a4 4 0 00-5.656 0L28 28M8 32l9.172-9.172a4 4 0 015.656 0L28 28m0 0l4 4m4-24h8m-4-4v8m-12 4h.02" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
            </svg>
            <div class="flex text-sm text-zinc-400 justify-center">
              <label for="file-upload" class="relative cursor-pointer rounded-md font-bold text-indigo-400 hover:text-indigo-300 focus-within:outline-none focus-within:ring-2 focus-within:ring-indigo-500">
                <span>Clique para selecionar</span>
                <%= f.file_field :file, id: "file-upload", class: "sr-only", required: true %>
              </label>
              <p class="pl-1 text-zinc-600">ou arraste e solte</p>
            </div>
            <p class="text-xs text-zinc-600">OFX ou CSV de até 10MB</p>
          </div>
        </div>
      </div>

      <div class="bg-indigo-500/5 border border-indigo-500/20 rounded-2xl p-5">
        <div class="flex gap-3">
          <div class="shrink-0">
            <svg class="h-5 w-5 text-indigo-400" viewBox="0 0 20 20" fill="currentColor">
              <path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7-4a1 1 0 11-2 0 1 1 0 012 0zM9 9a1 1 0 000 2v3a1 1 0 001 1h1a1 1 0 100-2v-3a1 1 0 00-1-1H9z" clip-rule="evenodd" />
            </svg>
          </div>
          <div>
            <h3 class="text-sm font-bold text-indigo-300">Dica sobre o formato CSV</h3>
            <p class="mt-1 text-sm text-zinc-400">O CSV deve conter os cabeçalhos: <strong class="text-zinc-200">date</strong>, <strong class="text-zinc-200">description</strong>, <strong class="text-zinc-200">amount</strong> e <strong class="text-zinc-200">type</strong> (income/expense).</p>
          </div>
        </div>
      </div>
    </div>

    <div class="flex flex-col sm:flex-row gap-4 pt-4">
      <%= link_to "Cancelar", dashboard_transactions_path, class: "flex-1 text-center bg-zinc-900 hover:bg-zinc-800 text-zinc-500 font-bold py-4 rounded-2xl border border-zinc-800 transition-all" %>
      <%= f.submit "Iniciar Importação", class: "flex-1 bg-indigo-600 hover:bg-indigo-500 text-white font-bold py-4 rounded-2xl transition-all shadow-xl shadow-indigo-500/25 cursor-pointer" %>
    </div>
  <% end %>
</div>
