<div class="max-w-2xl mx-auto">
  <%= render "shared/section_header", title: @page_title, subtitle: "Defina metas financeiras e acompanhe seu progresso." %>

  <%= form_with model: [:dashboard, @goal], class: "space-y-6" do |f| %>
    <%= render layout: "shared/card", locals: { class: "bg-zinc-900/60 shadow-2xl space-y-8" } do %>
      <%= render layout: "shared/field", locals: { f: f, field: :name, label: "Nome da Meta" } do %>
        <%= f.text_field :name, placeholder: "Ex: Reserva de Emergência, Viagem...", class: "w-full bg-zinc-950 border border-zinc-800 rounded-2xl px-5 py-4 text-zinc-100 text-lg font-bold focus:border-indigo-500 outline-none transition-all placeholder:text-zinc-700" %>
      <% end %>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
        <%= render layout: "shared/field", locals: { f: f, field: :target_amount, label: "Valor Objetivo (R$)" } do %>
          <%= f.number_field :target_amount, step: 0.01, value: @goal.target_amount.present? && @goal.target_amount > 0 ? @goal.target_amount / 100.0 : nil, class: "w-full bg-zinc-950 border border-zinc-800 rounded-2xl px-5 py-4 text-zinc-100 text-lg font-bold focus:border-indigo-500 outline-none transition-all tabular-nums" %>
          <% if current_user.monthly_salary&.positive? %>
            <% suggested_monthly = (current_user.monthly_salary * 0.1).to_i %>
            <p class="text-xs text-zinc-500 mt-1 ml-1">10% do salário = <%= number_to_currency(suggested_monthly / 100.0) %>/mês</p>
          <% end %>
        <% end %>
        
        <%= render layout: "shared/field", locals: { f: f, field: :current_amount, label: "Valor Acumulado (R$)" } do %>
          <%= f.number_field :current_amount, step: 0.01, value: @goal.current_amount.present? && @goal.current_amount > 0 ? @goal.current_amount / 100.0 : nil, class: "w-full bg-zinc-950 border border-zinc-800 rounded-2xl px-5 py-4 text-zinc-100 font-bold focus:border-indigo-500 outline-none transition-all tabular-nums" %>
        <% end %>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
        <%= render layout: "shared/field", locals: { f: f, field: :deadline, label: "Prazo (Opcional)" } do %>
          <%= f.date_field :deadline, class: "w-full bg-zinc-950 border border-zinc-800 rounded-2xl px-5 py-4 text-zinc-100 font-bold focus:border-indigo-500 outline-none transition-all" %>
          <% if current_user.monthly_salary&.positive? && @goal.target_amount.present? && @goal.target_amount > 0 %>
            <% remaining = @goal.target_amount - (@goal.current_amount || 0) %>
            <% if remaining > 0 %>
              <% est_months = (remaining.to_f / (current_user.monthly_salary * 0.1)).ceil %>
              <p class="text-xs text-zinc-500 mt-1 ml-1">~<%= est_months %> meses reservando 10% do salário</p>
            <% end %>
          <% end %>
        <% end %>

        <%= render "shared/color_picker", f: f, field: :color, label: "Cor", colors: [["Índigo", "indigo"], ["Esmeralda", "emerald"], ["Céu", "sky"], ["Âmbar", "amber"], ["Rosa", "rose"], ["Roxo", "purple"]] %>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
        <%= render layout: "shared/field", locals: { f: f, field: :icon, label: "Ícone (Emoji)" } do %>
          <%= f.text_field :icon, placeholder: "🎯, ✈️, 🛡️...", class: "w-full bg-zinc-950 border border-zinc-800 rounded-2xl px-5 py-4 text-zinc-100 text-2xl text-center focus:border-indigo-500 outline-none transition-all" %>
        <% end %>
        
        <%= render layout: "shared/field", locals: { f: f, field: :status, label: "Status" } do %>
          <%= f.select :status, [["Ativa", "active"], ["Pausada", "paused"], ["Concluída", "completed"]], {}, class: "w-full bg-zinc-950 border border-zinc-800 rounded-2xl px-5 py-4 text-zinc-100 font-bold focus:border-indigo-500 outline-none transition-all" %>
        <% end %>
      </div>
    <% end %>

    <%= render "shared/submit_bar", f: f, cancel_path: dashboard_goals_path, submit_label: "Salvar Meta" %>

    <% if @goal.persisted? %>
      <%= render "shared/danger_zone", resource: @goal, path: dashboard_goal_path(@goal), confirm_message: "Excluir esta meta permanentemente?", button_label: "Excluir Meta" %>
    <% end %>
  <% end %>
</div>
