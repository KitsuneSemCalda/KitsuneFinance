<div class="flex flex-col md:flex-row justify-between items-start md:items-center mb-8 gap-4">
  <div>
    <h2 class="text-2xl font-bold text-zinc-100">Minhas Metas</h2>
    <p class="text-zinc-500 text-sm">Planeje e acompanhe seus objetivos financeiros.</p>
  </div>
  <div class="flex flex-wrap items-center gap-3">
    <%= link_to dashboard_goals_path(format: :csv), class: "bg-zinc-800 hover:bg-zinc-700 text-zinc-200 font-medium py-2 px-4 rounded-xl transition-all flex items-center gap-2 text-sm border border-zinc-700" do %>
      <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5l5 5v11a2 2 0 01-2 2z" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
      Exportar CSV
    <% end %>
    <%= link_to dashboard_goals_path(format: :xlsx), class: "bg-zinc-800 hover:bg-zinc-700 text-zinc-200 font-medium py-2 px-4 rounded-xl transition-all flex items-center gap-2 text-sm border border-zinc-700" do %>
      <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path d="M9 17v-2m3 2v-4m3 4v-6m2 10H7a2 2 0 01-2-2V5a2 2 0 012-2h5l5 5v11a2 2 0 01-2 2z" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
      Exportar Excel
    <% end %>
    <%= link_to new_dashboard_goal_path, class: "bg-indigo-600 hover:bg-indigo-500 text-white font-medium py-2 px-4 rounded-xl transition-all shadow-lg shadow-indigo-500/25 flex items-center gap-2" do %>
      <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path d="M12 4v16m8-8H4" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
      Nova Meta
    <% end %>
  </div>
</div>

<div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-6">
  <% @goals.each do |goal| %>
    <div class="bg-zinc-900/60 border border-zinc-800/60 rounded-2xl p-6 relative overflow-hidden group">
      <div class="absolute -top-10 -right-10 w-32 h-32 bg-<%= goal.color %>-500/10 rounded-full blur-2xl group-hover:bg-<%= goal.color %>-500/20 transition-all"></div>
      
      <div class="flex items-center justify-between mb-6">
        <div class="flex items-center gap-3">
          <div class="w-10 h-10 rounded-xl bg-<%= goal.color %>-500/20 flex items-center justify-center text-xl">
            <%= goal.icon %>
          </div>
          <h3 class="font-bold text-zinc-100"><%= goal.name %></h3>
        </div>
        <span class="text-[10px] font-bold uppercase tracking-widest px-2 py-1 rounded bg-zinc-800 text-zinc-500">
          <%= goal.status %>
        </span>
      </div>

      <div class="mb-4">
        <div class="flex justify-between items-end mb-2">
          <span class="text-xs text-zinc-500">Progresso</span>
          <span class="text-sm font-bold text-zinc-100"><%= number_to_percentage(goal.progress_pct, precision: 1) %></span>
        </div>
        <div class="h-2 bg-zinc-800 rounded-full overflow-hidden">
          <div class="h-full bg-gradient-to-r from-<%= goal.color %>-500 to-<%= goal.color %>-400 rounded-full transition-all duration-700" style="width: <%= goal.progress_pct %>%"></div>
        </div>
      </div>

      <div class="flex justify-between mb-6">
        <div>
          <span class="text-[10px] text-zinc-500 block uppercase tracking-wider">Acumulado</span>
          <p class="text-sm font-bold text-zinc-100"><%= number_to_currency(goal.current_amount / 100.0, unit: "R$ ", separator: ",", delimiter: ".") %></p>
        </div>
        <div class="text-right">
          <span class="text-[10px] text-zinc-500 block uppercase tracking-wider">Objetivo</span>
          <p class="text-sm font-bold text-zinc-400"><%= number_to_currency(goal.target_amount / 100.0, unit: "R$ ", separator: ",", delimiter: ".") %></p>
        </div>
      </div>

      <div class="mt-4 flex flex-col gap-2">
        <p class="text-[10px] text-zinc-500 uppercase tracking-widest font-semibold">Contribuir</p>
        <%= form_with url: contribute_dashboard_goal_path(goal), method: :patch, class: "flex flex-col gap-2" do |f| %>
          <div class="flex gap-2">
            <%= f.select :account_id, options_from_collection_for_select(@accounts, :id, :name), {}, class: "flex-1 bg-zinc-950 border border-zinc-800 rounded-lg px-3 py-1.5 text-[10px] text-zinc-300 focus:border-#{goal.color}-500 outline-none" %>
            <%= f.number_field :amount, step: 1, placeholder: "Valor (centavos)", class: "w-24 bg-zinc-950 border border-zinc-800 rounded-lg px-3 py-1.5 text-[10px] text-zinc-100 focus:border-#{goal.color}-500 outline-none" %>
          </div>
          <%= f.submit "Registrar Contribuição", class: "w-full bg-zinc-800 hover:bg-zinc-700 text-zinc-200 py-2 rounded-lg text-[10px] font-bold uppercase tracking-wider transition-colors cursor-pointer border border-zinc-700" %>
        <% end %>
      </div>
        
        <div class="flex gap-1 ml-auto">
          <%= link_to edit_dashboard_goal_path(goal), class: "p-2 text-zinc-500 hover:text-zinc-100 transition-colors" do %>
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
          <% end %>
        </div>
      </div>
    </div>
  <% end %>
</div>
