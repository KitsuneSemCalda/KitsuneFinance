<div class="flex flex-col md:flex-row justify-between items-start md:items-center mb-8 gap-4">
  <div>
    <h2 class="text-2xl font-bold text-zinc-100">Minhas Metas</h2>
    <p class="text-zinc-500 text-sm">Planeje e realize seus sonhos financeiros.</p>
  </div>
  <div class="flex flex-wrap items-center gap-3">
    <div class="flex items-center bg-zinc-900 border border-zinc-800 rounded-xl overflow-hidden p-1 mr-2">
      <%= link_to dashboard_goals_path(format: :csv), class: "p-2 text-zinc-500 hover:text-indigo-400 hover:bg-zinc-800 transition-all rounded-lg", title: "Exportar CSV" do %>
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5l5 5v11a2 2 0 01-2 2z" stroke-width="2"/></svg>
      <% end %>
      <%= link_to dashboard_goals_path(format: :xlsx), class: "p-2 text-zinc-500 hover:text-emerald-400 hover:bg-zinc-800 transition-all rounded-lg", title: "Exportar Excel" do %>
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path d="M9 17v-2m3 2v-4m3 4v-6m2 10H7a2 2 0 01-2-2V5a2 2 0 012-2h5l5 5v11a2 2 0 01-2 2z" stroke-width="2"/></svg>
      <% end %>
    </div>

    <%= link_to new_dashboard_goal_path, class: "bg-indigo-600 hover:bg-indigo-500 text-white font-bold py-2.5 px-5 rounded-xl transition-all shadow-lg shadow-indigo-500/25 flex items-center gap-2 text-xs uppercase tracking-widest" do %>
      <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path d="M12 4v16m8-8H4" stroke-linecap="round" stroke-linejoin="round"/></svg>
      Nova Meta
    <% end %>
  </div>
</div>

<div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-6">
  <% @goals.each do |goal| %>
    <div class="bg-zinc-900/60 border border-zinc-800/60 rounded-3xl p-6 relative group overflow-hidden transition-all hover:bg-zinc-900/80">
      <div class="absolute -top-10 -right-10 w-32 h-32 bg-<%= goal.color %>-500/5 rounded-full blur-3xl group-hover:bg-<%= goal.color %>-500/10 transition-all"></div>
      
      <div class="flex items-center justify-between mb-8 relative z-10">
        <div class="flex items-center gap-4">
          <div class="w-14 h-14 rounded-2xl bg-<%= goal.color %>-500/10 border border-<%= goal.color %>-500/20 flex items-center justify-center text-3xl transition-transform group-hover:scale-110">
            <%= goal.icon %>
          </div>
          <div>
            <h3 class="text-lg font-bold text-zinc-100"><%= goal.name %></h3>
            <span class="inline-flex items-center gap-1.5 px-2 py-0.5 rounded-md text-[9px] font-black uppercase tracking-widest <%= goal.status == 'active' ? 'bg-indigo-500/10 text-indigo-400' : 'bg-zinc-800 text-zinc-500' %>">
              <%= goal.status %>
            </span>
          </div>
        </div>
        <%= link_to edit_dashboard_goal_path(goal), class: "p-2 text-zinc-600 hover:text-zinc-100 bg-zinc-800/50 rounded-xl transition-all opacity-0 group-hover:opacity-100" do %>
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" stroke-width="2"/></svg>
        <% end %>
      </div>

      <div class="mb-6 relative z-10">
        <div class="flex justify-between items-end mb-2.5">
          <span class="text-[10px] font-bold text-zinc-500 uppercase tracking-[0.15em]">Progresso</span>
          <span class="text-sm font-black tabular-nums text-zinc-100">
            <%= number_to_percentage(goal.progress_pct, precision: 1) %>
          </span>
        </div>
        <div class="h-2.5 bg-zinc-950 rounded-full overflow-hidden border border-zinc-800/50 p-0.5">
          <div class="h-full rounded-full transition-all duration-1000 bg-gradient-to-r from-<%= goal.color %>-600 to-<%= goal.color %>-400 shadow-[0_0_10px_rgba(var(--tw-color-<%= goal.color %>-500),0.3)]" style="width: <%= goal.progress_pct %>%"></div>
        </div>
      </div>

      <div class="flex justify-between mb-8 relative z-10">
        <div>
          <span class="text-[9px] text-zinc-500 font-bold uppercase tracking-widest block mb-0.5">Acumulado</span>
          <p class="text-base font-black text-zinc-100 tabular-nums"><%= number_to_currency(goal.current_amount / 100.0, unit: "R$ ") %></p>
        </div>
        <div class="text-right">
          <span class="text-[9px] text-zinc-500 font-bold uppercase tracking-widest block mb-0.5">Objetivo</span>
          <p class="text-base font-bold text-zinc-400 tabular-nums"><%= number_to_currency(goal.target_amount / 100.0, unit: "R$ ") %></p>
        </div>
      </div>

      <div class="pt-6 border-t border-zinc-800/60 relative z-10">
        <p class="text-[10px] font-bold text-zinc-500 uppercase tracking-widest mb-3 flex items-center gap-2">
          <svg class="w-3 h-3 text-indigo-500" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z" stroke-width="2"/></svg>
          Aporte Rápido
        </p>
        <%= form_with url: contribute_dashboard_goal_path(goal), method: :patch, class: "flex gap-2" do |f| %>
          <%= f.select :account_id, options_from_collection_for_select(@accounts, :id, :name), {}, class: "flex-1 bg-zinc-950 border border-zinc-800 rounded-xl px-3 py-2 text-[11px] font-bold text-zinc-400 focus:border-indigo-500 outline-none" %>
          <%= f.number_field :amount, step: 0.01, placeholder: "0,00", class: "w-20 bg-zinc-950 border border-zinc-800 rounded-xl px-3 py-2 text-[11px] font-black text-zinc-100 focus:border-indigo-500 outline-none tabular-nums" %>
          <%= f.submit "Ok", class: "bg-zinc-800 hover:bg-zinc-700 text-zinc-200 px-3 rounded-xl text-[10px] font-black uppercase transition-all cursor-pointer border border-zinc-700" %>
        <% end %>
      </div>
    </div>
  <% end %>

  <% if @goals.empty? %>
    <div class="col-span-full py-20 bg-zinc-900/20 border-2 border-dashed border-zinc-800 rounded-3xl text-center text-3xl">
      🎯
      <h3 class="text-lg font-bold text-zinc-300 mt-4">Nenhuma meta ativa</h3>
      <p class="text-zinc-500 text-sm mt-1">Crie objetivos para motivar sua economia mensal.</p>
      <%= link_to "Criar meta agora", new_dashboard_goal_path, class: "inline-block mt-6 bg-zinc-800 hover:bg-zinc-700 text-zinc-200 font-bold py-2.5 px-8 rounded-xl border border-zinc-700 transition-all" %>
    </div>
  <% end %>
</div>
