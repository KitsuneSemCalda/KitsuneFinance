<div class="flex justify-between items-center mb-8">
  <div>
    <h2 class="text-2xl font-bold text-zinc-100"><%= title %></h2>
    <% if local_assigns[:subtitle] %>
      <p class="text-zinc-500 text-sm"><%= subtitle %></p>
    <% end %>
  </div>
  <% if local_assigns[:action] %>
    <%= link_to action_path, class: "bg-indigo-600 hover:bg-indigo-500 text-white font-medium py-2.5 px-5 rounded-xl transition-all shadow-lg shadow-indigo-500/25 flex items-center gap-2 group" do %>
      <svg class="w-4 h-4 group-hover:rotate-90 transition-transform duration-300" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path d="M12 4v16m8-8H4" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
      <%= action %>
    <% end %>
  <% end %>
</div>
