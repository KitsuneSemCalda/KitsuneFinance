<% cancel_label = local_assigns[:cancel_label] || "Cancelar" %>
<% submit_label = local_assigns[:submit_label] || "Salvar" %>

<div class="flex flex-col sm:flex-row gap-4 pt-4">
  <%= link_to cancel_label, cancel_path, class: "flex-1 text-center bg-zinc-900 hover:bg-zinc-800 text-zinc-500 font-bold py-4 rounded-2xl border border-zinc-800 transition-all" %>
  <%= f.submit submit_label, class: "flex-1 bg-indigo-600 hover:bg-indigo-500 text-white font-bold py-4 rounded-2xl transition-all shadow-xl shadow-indigo-500/25 cursor-pointer" %>
</div>
