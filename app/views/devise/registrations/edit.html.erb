<div class="max-w-2xl w-full mx-auto p-8 bg-zinc-900/60 backdrop-blur-xl border border-zinc-800/60 shadow-2xl rounded-3xl relative overflow-hidden">
  <div class="absolute top-0 inset-x-0 h-1 bg-gradient-to-r from-emerald-500 via-teal-500 to-indigo-500"></div>
  
  <div class="mb-8 flex justify-between items-center">
    <div>
      <h2 class="text-3xl font-extrabold text-white mb-2 tracking-tight">Editar Perfil</h2>
      <p class="text-zinc-400 text-sm">Atualize suas configurações de conta.</p>
    </div>
    <%= link_to "Voltar", :back, class: "text-zinc-400 hover:text-white transition-colors text-sm font-medium px-4 py-2 bg-zinc-800/50 hover:bg-zinc-700/50 rounded-lg border border-zinc-700/50" %>
  </div>

  <%= form_for(resource, as: resource_name, url: registration_path(resource_name), html: { method: :put, class: "space-y-6" }) do |f| %>
    <%= render "devise/shared/error_messages", resource: resource %>

    <div class="space-y-5 bg-zinc-950/30 p-6 rounded-2xl border border-zinc-800/50">
      <h3 class="text-lg font-semibold text-zinc-200">Informações Básicas</h3>
      
      <div>
        <%= f.label :email, class: "block text-sm font-medium text-zinc-300 mb-1" %>
        <%= f.email_field :email, autofocus: true, autocomplete: "email", class: "w-full px-4 py-3 bg-zinc-900/80 border border-zinc-700 rounded-xl text-zinc-100 placeholder-zinc-500 focus:outline-none focus:ring-2 focus:ring-emerald-500/50 focus:border-emerald-500 transition-all" %>
      </div>

      <% if devise_mapping.confirmable? && resource.pending_reconfirmation? %>
        <div class="text-sm text-amber-400 bg-amber-500/10 border border-amber-500/20 px-4 py-3 rounded-xl">
          Aguardando confirmação para: <%= resource.unconfirmed_email %>
        </div>
      <% end %>
    </div>

    <div class="space-y-5 bg-zinc-950/30 p-6 rounded-2xl border border-zinc-800/50">
      <div class="flex justify-between items-baseline">
        <h3 class="text-lg font-semibold text-zinc-200">Alterar Senha</h3>
        <span class="text-xs text-zinc-500">(deixe em branco se não quiser alterar)</span>
      </div>
      
      <div>
        <%= f.label :password, "Nova senha", class: "block text-sm font-medium text-zinc-300 mb-1" %>
        <%= f.password_field :password, autocomplete: "new-password", class: "w-full px-4 py-3 bg-zinc-900/80 border border-zinc-700 rounded-xl text-zinc-100 placeholder-zinc-500 focus:outline-none focus:ring-2 focus:ring-emerald-500/50 focus:border-emerald-500 transition-all", placeholder: "••••••••" %>
        <% if @minimum_password_length %>
          <p class="text-xs text-zinc-500 mt-1.5"><%= @minimum_password_length %> caracteres mínimo</p>
        <% end %>
      </div>

      <div>
        <%= f.label :password_confirmation, "Confirmar nova senha", class: "block text-sm font-medium text-zinc-300 mb-1" %>
        <%= f.password_field :password_confirmation, autocomplete: "new-password", class: "w-full px-4 py-3 bg-zinc-900/80 border border-zinc-700 rounded-xl text-zinc-100 placeholder-zinc-500 focus:outline-none focus:ring-2 focus:ring-emerald-500/50 focus:border-emerald-500 transition-all", placeholder: "••••••••" %>
      </div>
    </div>

    <div class="space-y-5 bg-indigo-950/20 p-6 rounded-2xl border border-indigo-500/20 relative overflow-hidden">
      <div class="absolute inset-0 bg-gradient-to-r from-indigo-500/5 to-transparent pointer-events-none"></div>
      
      <div class="relative z-10">
        <div class="flex justify-between items-baseline mb-4">
          <h3 class="text-lg font-semibold text-indigo-300">Confirmação</h3>
          <span class="text-xs text-indigo-400/70">(necessário para salvar alterações)</span>
        </div>

        <div>
          <%= f.label :current_password, "Senha atual", class: "block text-sm font-medium text-indigo-200 mb-1" %>
          <%= f.password_field :current_password, autocomplete: "current-password", class: "w-full px-4 py-3 bg-zinc-900/80 border border-indigo-500/30 rounded-xl text-zinc-100 placeholder-zinc-500 focus:outline-none focus:ring-2 focus:ring-indigo-500/50 focus:border-indigo-500 transition-all", placeholder: "••••••••" %>
        </div>
      </div>
    </div>

    <div class="pt-4">
      <%= f.submit "Salvar Alterações", class: "w-full flex justify-center py-4 px-4 rounded-xl text-sm font-bold text-white bg-emerald-600 hover:bg-emerald-500 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-offset-zinc-900 focus:ring-emerald-500 transition-all shadow-lg shadow-emerald-500/25 cursor-pointer" %>
    </div>
  <% end %>

  <div class="mt-12 pt-8 border-t border-zinc-800/80">
    <h3 class="text-lg font-semibold text-red-400 mb-2">Zona de Perigo</h3>
    <p class="text-sm text-zinc-400 mb-4">Uma vez que você exclui sua conta, não há volta. Por favor, tenha certeza.</p>
    
    <%= button_to "Cancelar minha conta", registration_path(resource_name), data: { confirm: "Tem certeza absoluta?", turbo_confirm: "Tem certeza absoluta?" }, method: :delete, class: "w-full sm:w-auto px-6 py-3 bg-red-500/10 hover:bg-red-500/20 text-red-400 border border-red-500/20 hover:border-red-500/40 rounded-xl font-medium transition-all" %>
  </div>
</div>
