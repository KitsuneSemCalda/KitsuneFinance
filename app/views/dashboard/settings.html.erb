<div class="mb-8">
  <h2 class="text-2xl font-bold text-zinc-100">Configurações</h2>
  <p class="text-zinc-500 text-sm">Gerencie sua conta e preferências do sistema.</p>
</div>

<%# ── TAB NAVIGATION ── %>
<% tabs = [
  { id: "profile", label: "Perfil", icon: "M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" },
  { id: "preferences", label: "Preferências", icon: "M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z" },
  { id: "dashboard", label: "Dashboard", icon: "M4 5a1 1 0 011-1h4a1 1 0 011 1v5a1 1 0 01-1 1H5a1 1 0 01-1-1V5zm10 0a1 1 0 011-1h4a1 1 0 011 1v3a1 1 0 01-1 1h-4a1 1 0 01-1-1V5zM4 16a1 1 0 011-1h4a1 1 0 011 1v3a1 1 0 01-1 1H5a1 1 0 01-1-1v-3zm10-3a1 1 0 011-1h4a1 1 0 011 1v5a1 1 0 01-1 1h-4a1 1 0 01-1-1v-5z" },
  { id: "integrations", label: "Integrações", icon: "M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" },
  { id: "account", label: "Conta", icon: "M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4c-.77-.833-1.964-.833-2.732 0L4.082 16.5c-.77.833.192 2.5 1.732 2.5z" }
] %>

<div class="flex flex-wrap gap-1 mb-8 p-1 bg-zinc-900/60 border border-zinc-800/60 rounded-2xl">
  <% tabs.each do |tab| %>
    <%= link_to dashboard_settings_path(tab: tab[:id]),
          class: "flex items-center gap-2 px-4 py-2.5 rounded-xl text-xs font-bold uppercase tracking-wider transition-all #{
            @tab == tab[:id] ? 'bg-indigo-600 text-white shadow-lg shadow-indigo-500/25' : 'text-zinc-400 hover:text-zinc-100 hover:bg-zinc-800/60'
          }" do %>
      <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.75"><path d="<%= tab[:icon] %>"/></svg>
      <%= tab[:label] %>
    <% end %>
  <% end %>
</div>

<div class="max-w-3xl">
  <%# ── TAB: Perfil ── %>
  <% if @tab == "profile" %>
    <div class="bg-zinc-900/60 border border-zinc-800/60 rounded-2xl overflow-hidden">
      <div class="px-6 py-4 border-b border-zinc-800/60 bg-zinc-800/20">
        <h3 class="text-sm font-bold text-zinc-100">Perfil do Usuário</h3>
      </div>
      <div class="p-6 space-y-6">
        <div class="flex items-center gap-6">
          <div class="w-20 h-20 rounded-full bg-gradient-to-br from-indigo-500 to-violet-600 flex items-center justify-center text-3xl font-bold text-white shadow-xl shadow-indigo-500/20">
            <%= @user.email.first.upcase %>
          </div>
          <div>
            <p class="text-sm font-bold text-zinc-100"><%= @user.email.split('@').first.capitalize %></p>
            <p class="text-xs text-zinc-500"><%= @user.email %></p>
            <span class="inline-block mt-2 px-2 py-0.5 rounded bg-indigo-500/10 text-indigo-400 text-[10px] font-bold uppercase tracking-wider border border-indigo-500/20">Membro Premium</span>
          </div>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          <div class="space-y-1.5">
            <label class="text-[10px] font-bold uppercase tracking-widest text-zinc-500">Endereço de E-mail</label>
            <input type="text" value="<%= @user.email %>" readonly class="w-full bg-zinc-950 border border-zinc-800 rounded-xl px-4 py-2.5 text-sm text-zinc-400 cursor-not-allowed">
          </div>
          <div class="space-y-1.5">
            <label class="text-[10px] font-bold uppercase tracking-widest text-zinc-500">Data de Cadastro</label>
            <input type="text" value="<%= @user.created_at.strftime("%d de %B de %Y") %>" readonly class="w-full bg-zinc-950 border border-zinc-800 rounded-xl px-4 py-2.5 text-sm text-zinc-400 cursor-not-allowed">
          </div>
        </div>
      </div>
    </div>

  <%# ── TAB: Preferências ── %>
  <% elsif @tab == "preferences" %>
    <%= form_with model: @user, url: dashboard_settings_path(tab: "preferences"), method: :patch, class: "space-y-6" do |f| %>
      <div class="bg-zinc-900/60 border border-zinc-800/60 rounded-2xl overflow-hidden">
        <div class="px-6 py-4 border-b border-zinc-800/60 bg-zinc-800/20">
          <h3 class="text-sm font-bold text-zinc-100">Preferências Gerais</h3>
        </div>
        <div class="p-6 space-y-6">
          <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <div class="space-y-1.5">
              <%= f.label :primary_currency, "Moeda Principal", class: "text-[10px] font-bold uppercase tracking-widest text-zinc-500" %>
              <%= f.select :primary_currency, [["Real Brasileiro (R$)", "BRL"], ["Dólar Americano (US$)", "USD"], ["Euro (€)", "EUR"]], {}, class: "w-full bg-zinc-950 border border-zinc-800 rounded-xl px-4 py-2.5 text-sm text-zinc-100 focus:border-indigo-500 outline-none transition-colors" %>
            </div>
            <div class="space-y-1.5">
              <%= f.label :locale, "Idioma", class: "text-[10px] font-bold uppercase tracking-widest text-zinc-500" %>
              <%= f.select :locale, [["Português (Brasil)", "pt-BR"], ["English", "en"]], {}, class: "w-full bg-zinc-950 border border-zinc-800 rounded-xl px-4 py-2.5 text-sm text-zinc-100 focus:border-indigo-500 outline-none transition-colors" %>
            </div>
            <div class="space-y-1.5 md:col-span-2">
              <%= f.label :monthly_salary, "Salário (R$) / mês", class: "text-[10px] font-bold uppercase tracking-widest text-zinc-500" %>
              <%= f.number_field :monthly_salary, value: @user.monthly_salary&.positive? ? @user.monthly_salary / 100.0 : nil, step: 0.01, class: "w-full bg-zinc-950 border border-zinc-800 rounded-xl px-4 py-2.5 text-sm text-zinc-100 focus:border-indigo-500 outline-none transition-colors" %>
            </div>
          </div>
        </div>
      </div>
      <div class="flex justify-end">
        <%= f.submit "Salvar Preferências", class: "bg-indigo-600 hover:bg-indigo-500 text-white text-xs font-bold py-3 px-8 rounded-xl transition-all shadow-lg shadow-indigo-500/20 cursor-pointer" %>
      </div>
    <% end %>

  <%# ── TAB: Dashboard ── %>
  <% elsif @tab == "dashboard" %>
    <div class="bg-zinc-900/60 border border-zinc-800/60 rounded-2xl overflow-hidden">
      <div class="px-6 py-4 border-b border-zinc-800/60 bg-zinc-800/20">
        <h3 class="text-sm font-bold text-zinc-100">Personalizar Dashboard</h3>
      </div>
      <div class="p-6 space-y-4" id="dashboard-customizer">
        <p class="text-xs text-zinc-500">Escolha quais seções aparecem na sua Visão Geral:</p>
        <% widgets = [
          { id: "widget-kpi", label: "Indicadores Financeiros (KPI)" },
          { id: "widget-portfolio", label: "Portfólio de Investimentos" },
          { id: "widget-cashflow", label: "Fluxo de Caixa" },
          { id: "widget-budget", label: "Orçamento do Mês" },
          { id: "widget-debts", label: "Dívidas" },
          { id: "widget-health", label: "Saúde Financeira" },
          { id: "widget-transactions", label: "Últimas Transações" },
          { id: "widget-goals", label: "Metas" }
        ] %>
        <% widgets.each_with_index do |w, i| %>
          <label class="flex items-center gap-3 py-2 cursor-pointer group">
            <input type="checkbox" class="dash-toggle w-5 h-5 rounded-lg bg-zinc-800 border-zinc-700 text-indigo-500 focus:ring-indigo-500" data-widget="<%= w[:id] %>" checked>
            <span class="text-sm text-zinc-300 group-hover:text-zinc-100 transition-colors"><%= w[:label] %></span>
          </label>
        <% end %>
      </div>
    </div>

  <%# ── TAB: Integrações ── %>
  <% elsif @tab == "integrations" %>
    <%= form_with model: @user, url: dashboard_settings_path(tab: "integrations"), method: :patch, class: "space-y-6" do |f| %>
      <div class="bg-zinc-900/60 border border-zinc-800/60 rounded-2xl overflow-hidden">
        <div class="px-6 py-4 border-b border-zinc-800/60 bg-zinc-800/20">
          <h3 class="text-sm font-bold text-zinc-100">Integrações de API</h3>
        </div>
        <div class="p-6 space-y-6">
          <div class="space-y-1.5">
            <%= f.label :brapi_token, "Token BRAPI (Ações e FIIs)", class: "text-[10px] font-bold uppercase tracking-widest text-zinc-500" %>
            <%= f.password_field :brapi_token, placeholder: "Seu token da BRAPI", value: @user.brapi_token, class: "w-full bg-zinc-950 border border-zinc-800 rounded-xl px-4 py-2.5 text-sm text-zinc-100 focus:border-indigo-500 outline-none transition-colors" %>
          </div>
          <div class="space-y-1.5">
            <%= f.label :ntfy_url, "URL para Notificações (ntfy/Gotify)", class: "text-[10px] font-bold uppercase tracking-widest text-zinc-500" %>
            <%= f.text_field :ntfy_url, placeholder: "https://ntfy.sh/seu-topico", class: "w-full bg-zinc-950 border border-zinc-800 rounded-xl px-4 py-2.5 text-sm text-zinc-100 focus:border-indigo-500 outline-none transition-colors" %>
          </div>
        </div>
      </div>
      <div class="flex justify-end">
        <%= f.submit "Salvar Integrações", class: "bg-indigo-600 hover:bg-indigo-500 text-white text-xs font-bold py-3 px-8 rounded-xl transition-all shadow-lg shadow-indigo-500/20 cursor-pointer" %>
      </div>
    <% end %>

  <%# ── TAB: Conta ── %>
  <% elsif @tab == "account" %>
    <div class="space-y-6">
      <div class="bg-zinc-900/60 border border-zinc-800/60 rounded-2xl overflow-hidden">
        <div class="px-6 py-4 border-b border-zinc-800/60 bg-zinc-800/20">
          <h3 class="text-sm font-bold text-zinc-100">Backup de Dados</h3>
        </div>
        <div class="p-6">
          <p class="text-xs text-zinc-500 mb-4">Faça o download de uma cópia completa do seu banco de dados.</p>
          <%= link_to dashboard_backup_path, class: "inline-flex items-center gap-2 bg-zinc-800 hover:bg-zinc-700 text-zinc-200 text-xs font-bold py-3 px-6 rounded-xl transition-all border border-zinc-700" do %>
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"/></svg>
            Baixar Backup
          <% end %>
        </div>
      </div>

      <div class="bg-red-500/5 border border-red-500/10 rounded-2xl overflow-hidden">
        <div class="px-6 py-4 border-b border-red-500/10 bg-red-500/5">
          <h3 class="text-sm font-bold text-red-400">Zona de Perigo</h3>
        </div>
        <div class="p-6">
          <p class="text-xs text-zinc-500 mb-4">Ações irreversíveis que impactam sua conta permanentemente.</p>
          <button class="text-red-400 hover:text-red-300 text-xs font-bold transition-colors">
            Excluir minha conta e todos os dados
          </button>
        </div>
      </div>
    </div>
  <% end %>
</div>
