<div class="flex items-center justify-between mb-8">
  <div>
    <h2 class="text-2xl font-bold text-zinc-100">Notícias Financeiras</h2>
    <p class="text-zinc-500 text-sm">Últimas notícias do mercado financeiro.</p>
  </div>
  <div class="w-12 h-12 rounded-xl bg-zinc-800 flex items-center justify-center">
    <svg class="w-6 h-6 text-zinc-400" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z" stroke-width="2"/></svg>
  </div>
</div>

<% if @articles.any? %>
  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
    <% @articles.each do |article| %>
      <a href="<%= article[:link] %>" target="_blank" rel="noopener noreferrer" class="group block bg-zinc-900/40 border border-zinc-800/60 rounded-2xl p-6 hover:bg-zinc-800/40 hover:border-zinc-700/60 transition-all">
        <div class="flex items-center gap-2 mb-3">
          <span class="text-[10px] font-bold uppercase tracking-widest text-indigo-400/80"><%= article[:source] %></span>
          <span class="text-zinc-600">·</span>
          <span class="text-[10px] text-zinc-500"><%= time_ago_in_words(article[:pub_date]) %></span>
        </div>
        <h3 class="text-sm font-bold text-zinc-200 group-hover:text-white transition-colors leading-relaxed line-clamp-3"><%= article[:title] %></h3>
        <div class="mt-4 flex items-center gap-1 text-[10px] font-bold text-zinc-600 group-hover:text-indigo-400 uppercase tracking-widest transition-colors">
          <span>Ler mais</span>
          <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path d="M14 5l7 7m0 0l-7 7m7-7H3" stroke-width="2.5"/></svg>
        </div>
      </a>
    <% end %>
  </div>
<% else %>
  <div class="flex flex-col items-center justify-center py-20 text-center">
    <div class="w-16 h-16 bg-zinc-800/40 rounded-3xl flex items-center justify-center mb-6">
      <svg class="w-8 h-8 text-zinc-600" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z" stroke-width="2"/></svg>
    </div>
    <h3 class="text-lg font-bold text-zinc-300">Nenhuma notícia disponível</h3>
    <p class="text-zinc-500 text-sm mt-1">Tente novamente mais tarde.</p>
  </div>
<% end %>