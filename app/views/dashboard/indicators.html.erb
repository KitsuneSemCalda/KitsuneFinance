<div class="flex items-center justify-between mb-8">
  <div>
    <h2 class="text-2xl font-bold text-zinc-100">Indicadores Econômicos</h2>
    <p class="text-zinc-500 text-sm">Principais indicadores da economia brasileira.</p>
  </div>
  <div class="w-12 h-12 rounded-xl bg-zinc-800 flex items-center justify-center">
    <svg class="w-6 h-6 text-zinc-400" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" stroke-width="2"/></svg>
  </div>
</div>

<div class="grid grid-cols-1 md:grid-cols-3 gap-6">
  <div class="bg-zinc-900/60 border border-zinc-800/60 rounded-2xl p-8">
    <div class="w-12 h-12 rounded-xl bg-indigo-500/10 flex items-center justify-center mb-4">
      <span class="text-2xl">🏦</span>
    </div>
    <p class="text-[10px] font-bold uppercase tracking-widest text-zinc-500 mb-1">Taxa Selic</p>
    <p class="text-4xl font-black text-zinc-100 tabular-nums">
      <% if @selic %>
        <%= number_to_percentage(@selic, precision: 2) %>
      <% else %>
        <span class="text-zinc-600 text-2xl">Indisponível</span>
      <% end %>
    </p>
    <p class="text-[10px] text-zinc-600 mt-2">Meta da taxa básica de juros</p>
  </div>

  <div class="bg-zinc-900/60 border border-zinc-800/60 rounded-2xl p-8">
    <div class="w-12 h-12 rounded-xl bg-emerald-500/10 flex items-center justify-center mb-4">
      <span class="text-2xl">📊</span>
    </div>
    <p class="text-[10px] font-bold uppercase tracking-widest text-zinc-500 mb-1">CDI</p>
    <p class="text-4xl font-black text-zinc-100 tabular-nums">
      <% if @cdi %>
        <%= number_to_percentage(@cdi, precision: 2) %>
      <% else %>
        <span class="text-zinc-600 text-2xl">Indisponível</span>
      <% end %>
    </p>
    <p class="text-[10px] text-zinc-600 mt-2">Taxa de referência para investimentos</p>
  </div>

  <div class="bg-zinc-900/60 border border-zinc-800/60 rounded-2xl p-8">
    <div class="w-12 h-12 rounded-xl bg-amber-500/10 flex items-center justify-center mb-4">
      <span class="text-2xl">📈</span>
    </div>
    <p class="text-[10px] font-bold uppercase tracking-widest text-zinc-500 mb-1">IPCA (Acumulado)</p>
    <p class="text-4xl font-black text-zinc-100 tabular-nums">
      <% if @ipca %>
        <%= number_to_percentage(@ipca, precision: 2) %>
      <% else %>
        <span class="text-zinc-600 text-2xl">Indisponível</span>
      <% end %>
    </p>
    <p class="text-[10px] text-zinc-600 mt-2">Índice oficial de inflação</p>
  </div>
</div>

<%= render layout: "shared/card", locals: { class: "bg-zinc-900/40 mt-8" } do %>
  <div class="text-[10px] text-zinc-600 leading-relaxed">
    <p class="font-bold text-zinc-500 uppercase tracking-widest mb-2">ℹ️ Sobre os Indicadores</p>
    <ul class="space-y-1 ml-4 list-disc">
      <li><strong class="text-zinc-400">Selic</strong> — Taxa básica de juros da economia brasileira, definida pelo COPOM.</li>
      <li><strong class="text-zinc-400">CDI</strong> — Taxa de referência para títulos bancários e CDBs, geralmente próxima à Selic.</li>
      <li><strong class="text-zinc-400">IPCA</strong> — Índice oficial de inflação do Brasil, calculado pelo IBGE.</li>
    </ul>
    <p class="mt-3">Dados fornecidos pelo Banco Central do Brasil via API BCB-SGS.</p>
  </div>
<% end %>