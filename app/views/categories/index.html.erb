<div class="flex justify-between items-center mb-8">
  <div>
    <h2 class="text-2xl font-bold text-zinc-100">Categorias</h2>
    <p class="text-zinc-500 text-sm">Organize suas transações por categorias personalizadas.</p>
  </div>
  <%= link_to new_dashboard_category_path, class: "bg-indigo-600 hover:bg-indigo-500 text-white font-medium py-2 px-4 rounded-xl transition-all shadow-lg shadow-indigo-500/25 flex items-center gap-2" do %>
    <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path d="M12 4v16m8-8H4" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
    Nova Categoria
  <% end %>
</div>

<div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
  <%# Income Categories %>
  <div>
    <div class="flex items-center justify-between mb-4">
      <h3 class="text-sm font-bold text-zinc-500 uppercase tracking-widest">Receitas</h3>
      <%= link_to new_dashboard_category_path(transaction_type: 'income'), class: "text-xs text-indigo-400 hover:text-indigo-300 transition-colors" do %>
        + Nova Categoria
      <% end %>
    </div>
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
      <% @categories.income.each do |category| %>
        <div class="bg-zinc-900/60 border border-zinc-800/60 rounded-xl p-4 flex items-center justify-between group">
          <div class="flex items-center gap-3">
            <div class="w-8 h-8 rounded-lg bg-<%= category.color %>-500/10 flex items-center justify-center text-lg">
              <%= category.icon %>
            </div>
            <div>
              <span class="text-sm font-medium text-zinc-100 block"><%= category.name %></span>
              <% if category.categorization_rules.any? %>
                <span class="text-[10px] text-zinc-500"><%= category.categorization_rules.count %> regras</span>
              <% end %>
            </div>
          </div>
          <div class="flex gap-1 opacity-0 group-hover:opacity-100 transition-opacity">
            <%= link_to edit_dashboard_category_path(category), class: "p-1 text-zinc-500 hover:text-zinc-100" do %>
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
            <% end %>
            <% unless category.system_default %>
              <%= button_to dashboard_category_path(category), method: :delete, class: "p-1 text-zinc-500 hover:text-red-400", data: { turbo_confirm: "Tem certeza?" } do %>
                <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
              <% end %>
            <% end %>
          </div>
        </div>
      <% end %>
    </div>
  </div>

  <%# Expense Categories %>
  <div>
    <div class="flex items-center justify-between mb-4">
      <h3 class="text-sm font-bold text-zinc-500 uppercase tracking-widest">Despesas</h3>
      <%= link_to new_dashboard_category_path(transaction_type: 'expense'), class: "text-xs text-indigo-400 hover:text-indigo-300 transition-colors" do %>
        + Nova Categoria
      <% end %>
    </div>
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
      <% @categories.expense.each do |category| %>
        <div class="bg-zinc-900/60 border border-zinc-800/60 rounded-xl p-4 flex items-center justify-between group">
          <div class="flex items-center gap-3">
            <div class="w-8 h-8 rounded-lg bg-<%= category.color %>-500/10 flex items-center justify-center text-lg">
              <%= category.icon %>
            </div>
            <div>
              <span class="text-sm font-medium text-zinc-100 block"><%= category.name %></span>
              <% if category.categorization_rules.any? %>
                <span class="text-[10px] text-zinc-500"><%= category.categorization_rules.count %> regras</span>
              <% end %>
            </div>
          </div>
          <div class="flex gap-1 opacity-0 group-hover:opacity-100 transition-opacity">
            <%= link_to edit_dashboard_category_path(category), class: "p-1 text-zinc-500 hover:text-zinc-100" do %>
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
            <% end %>
            <% unless category.system_default %>
              <%= button_to dashboard_category_path(category), method: :delete, class: "p-1 text-zinc-500 hover:text-red-400", data: { turbo_confirm: "Tem certeza?" } do %>
                <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
              <% end %>
            <% end %>
          </div>
        </div>
      <% end %>
    </div>
  </div>
</div>
