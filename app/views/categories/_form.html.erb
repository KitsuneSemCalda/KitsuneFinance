<div class="max-w-2xl mx-auto">
  <div class="mb-8">
    <h2 class="text-2xl font-bold text-zinc-100"><%= @page_title %></h2>
    <p class="text-zinc-500 text-sm">Personalize como você classifica seu dinheiro.</p>
  </div>

  <%= form_with model: [:dashboard, @category], class: "space-y-6" do |f| %>
    
    <div class="bg-zinc-900/60 border border-zinc-800/60 rounded-3xl p-8 shadow-2xl space-y-8">
      
      <%# ── TYPE SELECTOR ── %>
      <div class="space-y-3">
        <label class="text-[10px] font-bold text-zinc-500 uppercase tracking-widest ml-1">Fluxo de Caixa</label>
        <div class="flex bg-zinc-950 p-1 rounded-2xl border border-zinc-800">
          <% [["Despesa", "expense"], ["Receita", "income"]].each do |label, val| %>
            <label class="flex-1 cursor-pointer">
              <%= f.radio_button :transaction_type, val, class: "peer sr-only" %>
              <div class="py-3 text-center text-xs font-bold uppercase tracking-widest text-zinc-500 rounded-xl peer-checked:bg-zinc-800 peer-checked:text-zinc-100 transition-all">
                <%= label %>
              </div>
            </label>
          <% end %>
        </div>
      </div>

      <div class="space-y-2">
        <%= f.label :name, "Nome da Categoria", class: "text-[10px] font-bold text-zinc-500 uppercase tracking-widest ml-1" %>
        <%= f.text_field :name, placeholder: "Ex: Alimentação, Lazer, Dividendos...", class: "w-full bg-zinc-950 border border-zinc-800 rounded-2xl px-5 py-4 text-zinc-100 text-lg font-bold focus:border-indigo-500 outline-none transition-all placeholder:text-zinc-700", required: true %>
      </div>

      <%# ── IDENTITY & STYLE ── %>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
        <div class="space-y-3">
          <label class="text-[10px] font-bold text-zinc-500 uppercase tracking-widest ml-1">Cor</label>
          <div class="grid grid-cols-5 gap-2">
            <% %w[indigo emerald sky amber rose purple orange red zinc teal].each do |color| %>
              <label class="cursor-pointer">
                <%= f.radio_button :color, color, class: "peer sr-only" %>
                <div class="w-full aspect-square rounded-xl border-2 border-transparent bg-<%= color %>-500/20 hover:bg-<%= color %>-500/30 peer-checked:border-<%= color %>-500 transition-all flex items-center justify-center">
                  <div class="w-3 h-3 rounded-full bg-<%= color %>-500 shadow-[0_0_8px_rgba(var(--tw-color-<%= color %>-500),0.4)]"></div>
                </div>
              </label>
            <% end %>
          </div>
        </div>

        <div class="space-y-3" x-data="{ open: false, selected: '<%= @category.icon || '💰' %>' }">
          <label class="text-[10px] font-bold text-zinc-500 uppercase tracking-widest ml-1">Ícone</label>
          <%= f.hidden_field :icon, 'x-model': 'selected' %>
          
          <div class="relative">
            <button type="button" @click="open = !open" 
                    class="w-full bg-zinc-950 border border-zinc-800 rounded-2xl px-4 py-3.5 flex items-center justify-between text-zinc-100 focus:border-indigo-500 transition-all">
              <span x-text="selected" class="text-2xl"></span>
              <svg class="w-4 h-4 text-zinc-500" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path d="M19 9l-7 7-7-7" stroke-width="2.5"/></svg>
            </button>

            <div x-show="open" @click.away="open = false" x-cloak x-transition
                 class="absolute z-50 mt-2 w-full bg-zinc-900 border border-zinc-800 rounded-2xl p-4 grid grid-cols-6 gap-2 shadow-2xl backdrop-blur-xl">
              <% %w[💰 💸 💳 🏦 📈 📉 🍔 🍕 🍎 🛒 🚕 🚌 ✈️ ⛽ 🏠 🔌 💊 🩺 ⚽ 🎨 🎮 📚 🎁 👔 🛡️ 💎 💍 👟 👕 🎒].each do |emoji| %>
                <button type="button" @click="selected = '<%= emoji %>'; open = false" class="text-xl hover:bg-zinc-800 p-2 rounded-xl transition-all"><%= emoji %></button>
              <% end %>
            </div>
          </div>
        </div>
      </div>
    </div>

    <div class="flex flex-col sm:flex-row gap-4 pt-4">
      <%= link_to "Cancelar", dashboard_categories_path, class: "flex-1 text-center bg-zinc-900 hover:bg-zinc-800 text-zinc-500 font-bold py-4 rounded-2xl border border-zinc-800 transition-all" %>
      <%= f.submit "Salvar Categoria", class: "flex-1 bg-indigo-600 hover:bg-indigo-500 text-white font-bold py-4 rounded-2xl transition-all shadow-xl shadow-indigo-500/25 cursor-pointer" %>
    </div>
  <% end %>

  <%# ── AUTOMATION RULES ── %>
  <% if @category.persisted? %>
    <div class="mt-12 space-y-4">
      <div class="flex items-center justify-between px-2">
        <h3 class="text-[10px] font-black text-zinc-500 uppercase tracking-[0.2em]">Regras de Inteligência</h3>
        <p class="text-[9px] text-zinc-600 italic">O sistema aprende baseado em palavras-chave</p>
      </div>

      <div class="bg-zinc-900/40 border border-zinc-800/60 rounded-3xl p-8 space-y-6">
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
          <% if @category.categorization_rules.any? %>
            <% @category.categorization_rules.each do |rule| %>
              <div class="flex items-center justify-between bg-zinc-950/50 border border-zinc-800 rounded-xl px-4 py-3 group">
                <span class="text-xs font-bold text-zinc-300 uppercase tracking-tight"><%= rule.keyword %></span>
                <%= button_to dashboard_category_categorization_rule_path(@category, rule), method: :delete, class: "text-zinc-600 hover:text-red-400 transition-colors" do %>
                  <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" stroke-width="2"/></svg>
                <% end %>
              </div>
            <% end %>
          <% else %>
            <div class="col-span-full py-4 text-center">
              <p class="text-[10px] text-zinc-600 uppercase tracking-widest">Nenhuma regra ativa para esta categoria</p>
            </div>
          <% end %>
        </div>

        <%= form_with model: [:dashboard, @category, CategorizationRule.new], class: "flex gap-3 pt-4 border-t border-zinc-800/60" do |f| %>
          <%= f.text_field :keyword, placeholder: "Nova palavra-chave...", class: "flex-1 bg-zinc-950 border border-zinc-800 rounded-xl px-4 py-3 text-sm text-zinc-200 focus:border-indigo-500 outline-none transition-all placeholder:text-zinc-700" %>
          <%= f.submit "Adicionar", class: "bg-zinc-800 hover:bg-zinc-700 text-zinc-300 text-xs font-bold px-6 rounded-xl border border-zinc-700 transition-all cursor-pointer" %>
        <% end %>
      </div>
    </div>
    
    <div class="mt-12 pt-8 border-t border-zinc-800/60 flex justify-center">
      <% unless @category.system_default %>
        <%= button_to dashboard_category_path(@category), method: :delete, class: "text-red-500/40 hover:text-red-400 text-[10px] font-bold uppercase tracking-[0.2em] transition-colors", data: { turbo_confirm: "Excluir esta categoria permanentemente?" } do %>
          Excluir Categoria
        <% end %>
      <% end %>
    </div>
  <% end %>
</div>
