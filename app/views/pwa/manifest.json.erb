<%
  base_url = Rails.application.config.action_controller.relative_url_root.presence || ""
%>
{
  "name": "Kitsune Finance",
  "short_name": "Kitsune",
  "description": "Gestão Financeira Pessoal Self-Hosted",
  "start_url": "<%= base_url.present? ? base_url + "/" : "/" %>",
  "display": "standalone",
  "background_color": "#09090b",
  "theme_color": "#6366f1",
  "icons": [
    {
      "src": "<%= base_url %>/icon.svg",
      "sizes": "any",
      "type": "image/svg+xml",
      "purpose": "any"
    },
    {
      "src": "<%= base_url %>/icon.png",
      "sizes": "512x512",
      "type": "image/png",
      "purpose": "maskable"
    }
  ]
}
