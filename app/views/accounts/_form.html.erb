<div class="max-w-2xl mx-auto">
  <div class="mb-8">
    <h2 class="text-2xl font-bold text-zinc-100"><%= @page_title %></h2>
    <p class="text-zinc-500 text-sm">Configure os detalhes da sua conta financeira.</p>
  </div>

  <%= form_with model: [:dashboard, @account], class: "space-y-6" do |f| %>
    
    <%# ── CORE INFO ── %>
    <div class="bg-zinc-900/60 border border-zinc-800/60 rounded-3xl p-8 shadow-2xl space-y-6">
      <div class="space-y-2">
        <%= f.label :name, "Nome da Conta", class: "text-[10px] font-bold text-zinc-500 uppercase tracking-widest ml-1" %>
        <%= f.text_field :name, placeholder: "Ex: Nubank Principal, XP Investimentos...", class: "w-full bg-zinc-950 border border-zinc-800 rounded-2xl px-5 py-4 text-zinc-100 text-lg font-bold focus:border-indigo-500 focus:ring-4 focus:ring-indigo-500/10 outline-none transition-all placeholder:text-zinc-700", required: true, autofocus: true %>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <div class="space-y-2">
          <%= f.label :account_type, "Tipo de Conta", class: "text-[10px] font-bold text-zinc-500 uppercase tracking-widest ml-1" %>
          <%= f.select :account_type, [["Corrente", "checking"], ["Poupança", "savings"], ["Cartão de Crédito", "credit"], ["Investimento", "investment"], ["Dinheiro", "cash"], ["Carteira Digital", "wallet"]], {}, class: "w-full bg-zinc-950 border border-zinc-800 rounded-2xl px-5 py-4 text-zinc-100 focus:border-indigo-500 outline-none transition-all" %>
        </div>

        <div class="space-y-2">
          <%= f.label :balance, "Saldo Atual (R$)", class: "text-[10px] font-bold text-zinc-500 uppercase tracking-widest ml-1" %>
          <%= f.number_field :balance, step: 0.01, value: (@account.balance.to_f / 100), class: "w-full bg-zinc-950 border border-zinc-800 rounded-2xl px-5 py-4 text-zinc-100 text-lg font-bold focus:border-indigo-500 focus:ring-4 focus:ring-indigo-500/10 outline-none transition-all tabular-nums", required: true %>
        </div>
      </div>
    </div>

    <%# ── STYLE & IDENTITY ── %>
    <div class="bg-zinc-900/40 border border-zinc-800/60 rounded-3xl p-8 space-y-8">
      
      <div class="space-y-4">
        <label class="text-[10px] font-bold text-zinc-500 uppercase tracking-widest ml-1">Cor de Identidade</label>
        <div class="grid grid-cols-3 sm:grid-cols-6 gap-3">
          <% [["Índigo", "indigo"], ["Esmeralda", "emerald"], ["Céu", "sky"], ["Âmbar", "amber"], ["Rosa", "rose"], ["Roxo", "purple"]].each do |label, color| %>
            <label class="cursor-pointer group">
              <%= f.radio_button :color, color, class: "peer sr-only" %>
              <div class="flex flex-col items-center gap-2 p-3 rounded-2xl border border-zinc-800 bg-zinc-950/50 peer-checked:border-<%= color %>-500 peer-checked:bg-<%= color %>-500/10 transition-all hover:border-zinc-700">
                <div class="w-6 h-6 rounded-full bg-<%= color %>-500 shadow-[0_0_10px_rgba(var(--tw-color-<%= color %>-500),0.2)]"></div>
                <span class="text-[9px] font-bold text-zinc-500 peer-checked:text-<%= color %>-400 uppercase tracking-tighter"><%= label %></span>
              </div>
            </label>
          <% end %>
        </div>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-8 items-end">
        <div class="space-y-2">
          <%= f.label :icon, "Ícone (Emoji)", class: "text-[10px] font-bold text-zinc-500 uppercase tracking-widest ml-1" %>
          <%= f.text_field :icon, placeholder: "🏦, 💳, 💰...", class: "w-full bg-zinc-950 border border-zinc-800 rounded-2xl px-5 py-4 text-zinc-100 text-2xl text-center focus:border-indigo-500 outline-none transition-all" %>
        </div>
        
        <div class="space-y-2">
          <%= f.label :currency, "Moeda", class: "text-[10px] font-bold text-zinc-500 uppercase tracking-widest ml-1" %>
          <%= f.select :currency, [["Real (BRL)", "BRL"], ["Dólar (USD)", "USD"], ["Euro (EUR)", "EUR"]], {}, class: "w-full bg-zinc-950 border border-zinc-800 rounded-2xl px-5 py-4 text-zinc-100 focus:border-indigo-500 outline-none transition-all" %>
        </div>
      </div>
    </div>

    <%# ── ACTIONS ── %>
    <div class="flex flex-col sm:flex-row gap-4 pt-4">
      <%= link_to "Descartar", dashboard_accounts_path, class: "flex-1 text-center bg-zinc-900 hover:bg-zinc-800 text-zinc-500 font-bold py-4 rounded-2xl border border-zinc-800 transition-all" %>
      <%= f.submit "Salvar Conta", class: "flex-1 bg-indigo-600 hover:bg-indigo-500 text-white font-bold py-4 rounded-2xl transition-all shadow-xl shadow-indigo-500/25 cursor-pointer" %>
    </div>
    
    <% if @account.persisted? %>
      <div class="pt-8 border-t border-zinc-800/60 mt-8 flex justify-center">
        <%= button_to dashboard_account_path(@account), method: :delete, class: "text-red-500/60 hover:text-red-400 text-[10px] font-bold uppercase tracking-[0.2em] transition-colors", data: { turbo_confirm: "Tem certeza que deseja excluir esta conta? Todas as transações vinculadas serão removidas permanentemente." } do %>
          Excluir Conta Permanentemente
        <% end %>
      </div>
    <% end %>

  <% end %>
</div>
