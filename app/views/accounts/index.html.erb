<div class="flex justify-between items-center mb-8">
  <div>
    <h2 class="text-2xl font-bold text-zinc-100">Minhas Contas</h2>
    <p class="text-zinc-500 text-sm">Gerencie seus saldos e instituições financeiras.</p>
  </div>
  <%= link_to new_dashboard_account_path, class: "bg-indigo-600 hover:bg-indigo-500 text-white font-medium py-2 px-4 rounded-xl transition-all shadow-lg shadow-indigo-500/25 flex items-center gap-2" do %>
    <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path d="M12 4v16m8-8H4" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
    Nova Conta
  <% end %>
</div>

<div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-6">
  <% @accounts.each do |account| %>
    <div class="bg-zinc-900/60 border border-zinc-800/60 rounded-2xl p-6 relative group overflow-hidden">
      <div class="absolute -top-10 -right-10 w-32 h-32 bg-<%= account.color %>-500/10 rounded-full blur-2xl group-hover:bg-<%= account.color %>-500/20 transition-all"></div>
      
      <div class="flex items-center gap-4 mb-6">
        <div class="w-12 h-12 rounded-xl bg-<%= account.color %>-500/20 flex items-center justify-center text-2xl">
          <%= account.icon %>
        </div>
        <div>
          <h3 class="text-lg font-bold text-zinc-100"><%= account.name %></h3>
          <span class="text-xs text-zinc-500 uppercase tracking-wider"><%= t("account_types.#{account.account_type}") rescue account.account_type.capitalize %></span>
        </div>
      </div>

      <div class="mb-6">
        <span class="text-xs text-zinc-500 block mb-1">Saldo Atual</span>
        <p class="text-3xl font-bold text-zinc-100">
          <%= number_to_currency(account.balance, unit: "R$ ", separator: ",", delimiter: ".") %>
        </p>
      </div>

      <div class="flex justify-end gap-2">
        <%= link_to edit_dashboard_account_path(account), class: "p-2 text-zinc-500 hover:text-zinc-100 transition-colors" do %>
          <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"/></svg>
        <% end %>
        <%= button_to dashboard_account_path(account), method: :delete, class: "p-2 text-zinc-500 hover:text-red-400 transition-colors", data: { turbo_confirm: "Tem certeza?" } do %>
          <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"/></svg>
        <% end %>
      </div>
    </div>
  <% end %>
</div>
