<div class="flex justify-between items-center mb-8">
  <div>
    <h2 class="text-2xl font-bold text-zinc-100">Minhas Contas</h2>
    <p class="text-zinc-500 text-sm">Gerencie seus saldos e instituições financeiras.</p>
  </div>
  <%= link_to new_dashboard_account_path, class: "bg-indigo-600 hover:bg-indigo-500 text-white font-medium py-2.5 px-5 rounded-xl transition-all shadow-lg shadow-indigo-500/25 flex items-center gap-2 group" do %>
    <svg class="w-4 h-4 group-hover:rotate-90 transition-transform duration-300" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path d="M12 4v16m8-8H4" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
    Nova Conta
  <% end %>
</div>

<div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-6">
  <% @accounts.each do |account| %>
    <div class="bg-zinc-900/60 border border-zinc-800/60 rounded-3xl p-6 relative group overflow-hidden transition-all hover:border-<%= account.color %>-500/30 hover:bg-zinc-900/80">
      <div class="absolute -top-10 -right-10 w-32 h-32 bg-<%= account.color %>-500/5 rounded-full blur-3xl group-hover:bg-<%= account.color %>-500/10 transition-all"></div>
      
      <div class="flex items-center justify-between mb-8 relative z-10">
        <div class="flex items-center gap-4">
          <div class="w-14 h-14 rounded-2xl bg-<%= account.color %>-500/10 border border-<%= account.color %>-500/20 flex items-center justify-center text-3xl shadow-inner transition-transform group-hover:scale-110 duration-300">
            <%= account.icon %>
          </div>
          <div>
            <h3 class="text-lg font-bold text-zinc-100 group-hover:text-white transition-colors"><%= account.name %></h3>
            <span class="text-[10px] font-bold text-zinc-500 uppercase tracking-widest bg-zinc-800/50 px-2 py-0.5 rounded-md"><%= t("account_types.#{account.account_type}") rescue account.account_type.capitalize %></span>
          </div>
        </div>
        
        <div class="flex gap-1 opacity-0 group-hover:opacity-100 transition-opacity">
          <%= link_to edit_dashboard_account_path(account), class: "p-2 text-zinc-500 hover:text-zinc-100 bg-zinc-800/40 hover:bg-zinc-800 rounded-xl transition-all" do %>
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" stroke-width="1.75"/></svg>
          <% end %>
        </div>
      </div>

      <div class="mb-4 relative z-10">
        <span class="text-[10px] font-bold text-zinc-500 uppercase tracking-widest block mb-1 ml-1">Saldo Disponível</span>
        <p class="text-3xl font-black text-zinc-100 tabular-nums tracking-tight">
          <%= number_to_currency(account.balance / 100.0, unit: "R$ ", separator: ",", delimiter: ".") %>
        </p>
      </div>

      <div class="flex items-center justify-between pt-4 border-t border-zinc-800/60 relative z-10">
        <div class="flex items-center gap-1.5">
          <div class="w-2 h-2 rounded-full bg-emerald-500 shadow-[0_0_8px_rgba(16,185,129,0.4)]"></div>
          <span class="text-[10px] font-bold text-zinc-500 uppercase tracking-wider">Ativa</span>
        </div>
        <span class="text-[10px] font-medium text-zinc-600 italic">Atualizado <%= time_ago_in_words(account.updated_at) %> atrás</span>
      </div>
    </div>
  <% end %>
  
  <% if @accounts.empty? %>
    <div class="col-span-full py-20 bg-zinc-900/20 border-2 border-dashed border-zinc-800 rounded-3xl text-center">
      <div class="w-16 h-16 bg-zinc-800/40 rounded-2xl flex items-center justify-center mx-auto mb-4 text-zinc-600">
        <svg class="w-8 h-8" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path d="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z" stroke-width="2"/></svg>
      </div>
      <h3 class="text-lg font-bold text-zinc-300">Nenhuma conta encontrada</h3>
      <p class="text-zinc-500 text-sm mt-1">Adicione suas contas bancárias ou carteiras para começar.</p>
      <%= link_to "Criar primeira conta", new_dashboard_account_path, class: "inline-block mt-6 bg-zinc-800 hover:bg-zinc-700 text-zinc-200 font-bold py-2.5 px-6 rounded-xl border border-zinc-700 transition-all" %>
    </div>
  <% end %>
</div>
