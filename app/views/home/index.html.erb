<div class="flex flex-col items-center justify-center min-h-[70vh] w-full text-center relative overflow-hidden">
  <!-- Decorative background elements -->
  <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] bg-indigo-600/20 rounded-full blur-[120px] pointer-events-none"></div>
  <div class="absolute top-0 right-0 w-[400px] h-[400px] bg-emerald-600/10 rounded-full blur-[100px] pointer-events-none"></div>

  <div class="relative z-10 w-full max-w-4xl mx-auto px-4">
    <div class="inline-flex items-center justify-center px-3 py-1 mb-6 text-sm text-zinc-300 bg-zinc-800/50 border border-zinc-700/50 rounded-full backdrop-blur-sm">
      <span class="flex w-2 h-2 rounded-full bg-emerald-400 mr-2"></span>
      Bem-vindo ao novo Kitsune Finance
    </div>

    <h1 class="text-5xl md:text-7xl font-extrabold text-transparent bg-clip-text bg-gradient-to-r from-zinc-100 via-zinc-200 to-zinc-400 mb-6 tracking-tight">
      Sua vida financeira,<br/> simplificada e elegante.
    </h1>
    
    <% if user_signed_in? %>
      <div class="mt-12 bg-zinc-900/40 backdrop-blur-xl p-10 rounded-3xl border border-zinc-800/50 shadow-2xl relative overflow-hidden">
        <div class="absolute inset-0 bg-gradient-to-br from-indigo-500/5 to-transparent pointer-events-none"></div>
        
        <h2 class="text-3xl font-bold text-zinc-100 mb-2">Olá, <%= current_user.email.split('@').first.capitalize %>!</h2>
        <p class="text-zinc-400 mb-8 text-lg">Pronto para acompanhar seus rendimentos hoje?</p>
        
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <%= link_to "Acessar Painel", dashboard_path, class: "bg-indigo-600 hover:bg-indigo-500 text-white font-medium py-3 px-8 rounded-xl transition-all shadow-lg shadow-indigo-500/25 hover:shadow-indigo-500/40 hover:-translate-y-0.5" %>
          <%= link_to "Perfil", edit_user_registration_path, class: "bg-zinc-800 hover:bg-zinc-700 text-zinc-200 font-medium py-3 px-8 rounded-xl border border-zinc-700/50 transition-all hover:-translate-y-0.5" %>
          <%= button_to "Sair", destroy_user_session_path, method: :delete, class: "bg-transparent hover:bg-red-500/10 text-red-400 font-medium py-3 px-8 rounded-xl border border-red-500/20 hover:border-red-500/30 transition-all sm:ml-auto" %>
        </div>
      </div>
    <% else %>
      <p class="text-xl text-zinc-400 mb-10 max-w-2xl mx-auto leading-relaxed">
        Controle seus gastos, planeje seu futuro e tome decisões mais inteligentes com um painel financeiro criado para a melhor experiência do usuário.
      </p>
      
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <%= link_to "Começar Agora", new_user_registration_path, class: "bg-indigo-600 hover:bg-indigo-500 text-white font-medium py-3.5 px-8 rounded-xl transition-all shadow-lg shadow-indigo-500/25 hover:shadow-indigo-500/40 hover:-translate-y-0.5 text-lg" %>
        <%= link_to "Fazer Login", new_user_session_path, class: "bg-zinc-800 hover:bg-zinc-700 text-zinc-200 font-medium py-3.5 px-8 rounded-xl border border-zinc-700/50 transition-all hover:-translate-y-0.5 text-lg" %>
      </div>
      
      <div class="mt-16 pt-10 border-t border-zinc-800/50 text-sm text-zinc-500 flex justify-center gap-8">
        <div class="flex flex-col items-center gap-2">
          <svg class="w-6 h-6 text-indigo-400" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/></svg>
          Seguro & Privado
        </div>
        <div class="flex flex-col items-center gap-2">
          <svg class="w-6 h-6 text-emerald-400" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"/></svg>
          Análises Precisas
        </div>
        <div class="flex flex-col items-center gap-2">
          <svg class="w-6 h-6 text-sky-400" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2V6zM14 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2V6zM4 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2v-2zM14 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2v-2z"/></svg>
          Design Intuitivo
        </div>
      </div>
    <% end %>
  </div>
</div>
