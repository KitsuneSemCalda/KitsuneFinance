<div class="max-w-2xl mx-auto">
  <div class="flex justify-between items-center mb-8">
    <%= render "shared/section_header", title: "Alertas de Orçamento", subtitle: "Categorias que já atingiram 80% ou mais do limite." %>
  </div>

  <% if @alerts.any? %>
    <div class="space-y-4">
      <% @alerts.each do |budget| %>
        <div class="bg-amber-500/10 border border-amber-500/20 p-6 rounded-2xl flex items-center justify-between">
          <div>
            <h3 class="text-amber-400 font-bold"><%= budget.category.name %></h3>
            <p class="text-sm text-amber-500/80">Você já utilizou <%= number_to_percentage(budget.spent_amount.to_f / budget.limit_amount * 100, precision: 0) %> do limite.</p>
          </div>
          <div class="text-right">
            <span class="text-amber-400 font-black"><%= number_to_currency(budget.spent_amount / 100.0) %></span>
            <p class="text-xs text-amber-500/60 uppercase">de <%= number_to_currency(budget.limit_amount / 100.0) %></p>
          </div>
        </div>
      <% end %>
    </div>
  <% else %>
    <div class="text-center py-16 bg-zinc-900/40 rounded-2xl border border-zinc-800">
      <p class="text-zinc-500">Nenhum alerta de orçamento no momento. Tudo sob controle!</p>
    </div>
  <% end %>
</div>
