<div class="flex flex-col md:flex-row justify-between items-start md:items-center mb-8 gap-4">
  <div>
    <h2 class="text-2xl font-bold text-zinc-100">Orçamento</h2>
    <p class="text-zinc-500 text-sm">Controle seus gastos mensais por categoria.</p>
  </div>
  <div class="flex flex-wrap items-center gap-4">
    <div class="flex items-center bg-zinc-900 border border-zinc-800 rounded-xl px-3 py-2 text-sm text-zinc-400">
      <%= link_to dashboard_budgets_path(month: @month == 1 ? 12 : @month - 1, year: @month == 1 ? @year - 1 : @year), class: "hover:text-zinc-100 p-1 transition-colors" do %>
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path d="M15 19l-7-7 7-7" stroke-linecap="round" stroke-linejoin="round"/></svg>
      <% end %>
      <span class="mx-4 font-bold text-zinc-200 uppercase tracking-widest text-[11px]"><%= t("date.month_names")[@month] %> <%= @year %></span>
      <%= link_to dashboard_budgets_path(month: @month == 12 ? 1 : @month + 1, year: @month == 12 ? @year + 1 : @year), class: "hover:text-zinc-100 p-1 transition-colors" do %>
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path d="M9 5l7 7-7 7" stroke-linecap="round" stroke-linejoin="round"/></svg>
      <% end %>
    </div>
    
    <%= link_to new_dashboard_budget_path, class: "bg-indigo-600 hover:bg-indigo-500 text-white font-bold py-2.5 px-5 rounded-xl transition-all shadow-lg shadow-indigo-500/25 flex items-center gap-2 text-xs uppercase tracking-widest" do %>
      <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path d="M12 4v16m8-8H4" stroke-linecap="round" stroke-linejoin="round"/></svg>
      Definir Limite
    <% end %>
  </div>
</div>

<div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-6">
  <% @budgets.each do |budget| %>
    <div class="bg-zinc-900/60 border border-zinc-800/60 rounded-3xl p-6 relative group transition-all hover:bg-zinc-900/80">
      <div class="flex items-center justify-between mb-8">
        <div class="flex items-center gap-3">
          <div class="w-12 h-12 rounded-2xl bg-<%= budget.category.color %>-500/10 border border-<%= budget.category.color %>-500/20 flex items-center justify-center text-2xl transition-transform group-hover:scale-110">
            <%= budget.category.icon %>
          </div>
          <div>
            <h3 class="font-bold text-zinc-100"><%= budget.category.name %></h3>
            <span class="text-[9px] font-black text-zinc-500 uppercase tracking-widest">Categoria</span>
          </div>
        </div>
        <%= link_to edit_dashboard_budget_path(budget), class: "p-2 text-zinc-600 hover:text-zinc-100 bg-zinc-800/50 rounded-xl transition-all opacity-0 group-hover:opacity-100" do %>
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" stroke-width="2"/></svg>
        <% end %>
      </div>

      <div class="mb-6">
        <div class="flex justify-between items-end mb-2.5">
          <span class="text-[10px] font-bold text-zinc-500 uppercase tracking-[0.15em]">Consumo do Limite</span>
          <span class="text-sm font-black tabular-nums <%= budget.over_budget? ? 'text-red-400' : 'text-emerald-400' %>">
            <%= number_to_percentage(budget.progress_pct, precision: 1) %>
          </span>
        </div>
        <div class="h-2.5 bg-zinc-950 rounded-full overflow-hidden border border-zinc-800/50 p-0.5">
          <div class="h-full rounded-full transition-all duration-1000 bg-gradient-to-r <%= budget.over_budget? ? 'from-red-600 to-rose-400 shadow-[0_0_10px_rgba(244,63,94,0.3)]' : 'from-indigo-600 to-indigo-400 shadow-[0_0_10px_rgba(99,102,241,0.3)]' %>" style="width: <%= budget.progress_pct %>%"></div>
        </div>
      </div>

      <div class="flex justify-between pt-4 border-t border-zinc-800/60">
        <div>
          <span class="text-[9px] text-zinc-500 font-bold uppercase tracking-widest block mb-0.5">Gasto Atual</span>
          <p class="text-base font-black text-zinc-100 tabular-nums"><%= number_to_currency(budget.spent_amount / 100.0) %></p>
        </div>
        <div class="text-right">
          <span class="text-[9px] text-zinc-500 font-bold uppercase tracking-widest block mb-0.5">Limite Definido</span>
          <p class="text-base font-bold text-zinc-400 tabular-nums"><%= number_to_currency(budget.limit_amount / 100.0) %></p>
        </div>
      </div>
    </div>
  <% end %>
</div>

<% if @budgets.empty? %>
  <div class="py-20 bg-zinc-900/20 border-2 border-dashed border-zinc-800 rounded-3xl text-center">
    <div class="w-16 h-16 bg-zinc-800/40 rounded-2xl flex items-center justify-center mx-auto mb-4 text-zinc-600 text-3xl">
      📊
    </div>
    <h3 class="text-lg font-bold text-zinc-300">Nenhum orçamento para este mês</h3>
    <p class="text-zinc-500 text-sm mt-1">Defina limites por categoria para manter suas finanças sob controle.</p>
    <%= link_to "Começar agora", new_dashboard_budget_path(month: @month, year: @year), class: "inline-block mt-6 bg-indigo-600/10 hover:bg-indigo-600/20 text-indigo-400 font-bold py-2.5 px-8 rounded-xl border border-indigo-500/20 transition-all" %>
  </div>
<% end %>
