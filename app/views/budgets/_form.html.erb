<div class="max-w-2xl mx-auto bg-zinc-900/60 border border-zinc-800/60 rounded-3xl p-8 shadow-2xl">
  <h2 class="text-2xl font-bold text-zinc-100 mb-8"><%= @page_title %></h2>

  <%= form_with model: [:dashboard, @budget], class: "space-y-6" do |f| %>
    <div class="space-y-2">
      <%= f.label :category_id, "Categoria", class: "text-xs font-bold text-zinc-500 uppercase tracking-wider" %>
      <%= f.collection_select :category_id, current_user.categories.expense, :id, :name, { prompt: "Selecione a categoria" }, class: "w-full bg-zinc-950 border border-zinc-800 rounded-xl px-4 py-3 text-zinc-100 focus:border-indigo-500 outline-none transition-all" %>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      <div class="space-y-2">
        <%= f.label :month, "Mês", class: "text-xs font-bold text-zinc-500 uppercase tracking-wider" %>
        <%= f.select :month, (1..12).map { |m| [t("date.month_names")[m], m] }, {}, class: "w-full bg-zinc-950 border border-zinc-800 rounded-xl px-4 py-3 text-zinc-100 focus:border-indigo-500 outline-none transition-all" %>
      </div>

      <div class="space-y-2">
        <%= f.label :year, "Ano", class: "text-xs font-bold text-zinc-500 uppercase tracking-wider" %>
        <%= f.number_field :year, class: "w-full bg-zinc-950 border border-zinc-800 rounded-xl px-4 py-3 text-zinc-100 focus:border-indigo-500 outline-none transition-all" %>
      </div>
    </div>

    <div class="space-y-2">
      <%= f.label :limit_amount, "Limite de Gastos", class: "text-xs font-bold text-zinc-500 uppercase tracking-wider" %>
      <%= f.number_field :limit_amount, step: 0.01, class: "w-full bg-zinc-950 border border-zinc-800 rounded-xl px-4 py-3 text-zinc-100 focus:border-indigo-500 outline-none transition-all" %>
    </div>

    <div class="flex gap-4 pt-4">
      <%= link_to "Cancelar", dashboard_budgets_path, class: "flex-1 text-center bg-zinc-800 hover:bg-zinc-700 text-zinc-300 font-medium py-3 rounded-xl transition-all" %>
      <%= f.submit "Definir Limite", class: "flex-1 bg-indigo-600 hover:bg-indigo-500 text-white font-medium py-3 rounded-xl transition-all shadow-lg shadow-indigo-500/25 cursor-pointer" %>
    </div>
  <% end %>
</div>
