<div class="max-w-2xl mx-auto">
  <div class="mb-8">
    <h2 class="text-2xl font-bold text-zinc-100"><%= @page_title %></h2>
    <p class="text-zinc-500 text-sm">Defina limites de gastos por categoria e acompanhe seu orçamento.</p>
  </div>

  <%= form_with model: [:dashboard, @budget], class: "space-y-6" do |f| %>
    <div class="bg-zinc-900/60 border border-zinc-800/60 rounded-3xl p-8 shadow-2xl space-y-8">
      <div class="space-y-2">
        <%= f.label :category_id, "Categoria", class: "text-[10px] font-bold text-zinc-500 uppercase tracking-widest ml-1" %>
        <%= f.collection_select :category_id, current_user.categories.expense, :id, :name, { prompt: "Selecione a categoria" }, class: "w-full bg-zinc-950 border border-zinc-800 rounded-2xl px-5 py-4 text-zinc-100 font-bold focus:border-indigo-500 outline-none transition-all" %>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
        <div class="space-y-2">
          <%= f.label :month, "Mês", class: "text-[10px] font-bold text-zinc-500 uppercase tracking-widest ml-1" %>
          <%= f.select :month, (1..12).map { |m| [t("date.month_names")[m], m] }, {}, class: "w-full bg-zinc-950 border border-zinc-800 rounded-2xl px-5 py-4 text-zinc-100 font-bold focus:border-indigo-500 outline-none transition-all" %>
        </div>
        <div class="space-y-2">
          <%= f.label :year, "Ano", class: "text-[10px] font-bold text-zinc-500 uppercase tracking-widest ml-1" %>
          <%= f.number_field :year, class: "w-full bg-zinc-950 border border-zinc-800 rounded-2xl px-5 py-4 text-zinc-100 font-bold focus:border-indigo-500 outline-none transition-all" %>
        </div>
      </div>

      <div class="space-y-2">
        <%= f.label :limit_amount, "Limite de Gastos (R$)", class: "text-[10px] font-bold text-zinc-500 uppercase tracking-widest ml-1" %>
        <%= f.number_field :limit_amount, step: 0.01, value: @budget.limit_amount.present? ? @budget.limit_amount / 100.0 : nil, class: "w-full bg-zinc-950 border border-zinc-800 rounded-2xl px-5 py-4 text-zinc-100 text-lg font-bold focus:border-indigo-500 outline-none transition-all tabular-nums" %>
        <% if current_user.monthly_salary&.positive? %>
          <% suggested = (current_user.monthly_salary * 0.1).to_i %>
          <p class="text-xs text-zinc-500 mt-1 ml-1">Sugestão: 10% do salário = <%= number_to_currency(suggested / 100.0, unit: "R$ ", separator: ",", delimiter: ".") %></p>
        <% end %>
      </div>
    </div>

    <div class="flex flex-col sm:flex-row gap-4 pt-4">
      <%= link_to "Cancelar", dashboard_budgets_path, class: "flex-1 text-center bg-zinc-900 hover:bg-zinc-800 text-zinc-500 font-bold py-4 rounded-2xl border border-zinc-800 transition-all" %>
      <%= f.submit "Definir Limite", class: "flex-1 bg-indigo-600 hover:bg-indigo-500 text-white font-bold py-4 rounded-2xl transition-all shadow-xl shadow-indigo-500/25 cursor-pointer" %>
    </div>
  <% end %>
</div>
