<div class="max-w-2xl mx-auto">
  <div class="mb-8">
    <h2 class="text-2xl font-bold text-zinc-100">Editar Dívida</h2>
    <p class="text-zinc-500 text-sm">Atualize os dados do seu compromisso financeiro.</p>
  </div>

  <%= form_with model: [:dashboard, @debt], class: "space-y-6" do |f| %>
    <div class="bg-zinc-900/60 border border-zinc-800/60 rounded-3xl p-8 shadow-2xl space-y-8">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <div class="space-y-2">
          <%= f.label :name, "Nome da Dívida", class: "text-[10px] font-bold text-zinc-500 uppercase tracking-widest ml-1" %>
          <%= f.text_field :name, placeholder: "Ex: Financiamento imobiliário, cartão de crédito...", class: "w-full bg-zinc-950 border border-zinc-800 rounded-2xl px-5 py-4 text-zinc-100 font-bold focus:border-indigo-500 outline-none transition-all placeholder:text-zinc-700", required: true %>
        </div>
        <div class="space-y-2">
          <%= f.label :total_amount, "Valor Total (R$)", class: "text-[10px] font-bold text-zinc-500 uppercase tracking-widest ml-1" %>
          <%= f.number_field :total_amount, step: 0.01, value: @debt.total_amount.present? ? @debt.total_amount / 100.0 : nil, class: "w-full bg-zinc-950 border border-zinc-800 rounded-2xl px-5 py-4 text-zinc-100 text-lg font-bold focus:border-indigo-500 outline-none transition-all tabular-nums", required: true %>
        </div>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <div class="space-y-2">
          <%= f.label :monthly_payment, "Valor da Parcela (R$)", class: "text-[10px] font-bold text-zinc-500 uppercase tracking-widest ml-1" %>
          <%= f.number_field :monthly_payment, step: 0.01, value: @debt.monthly_payment.present? ? @debt.monthly_payment / 100.0 : nil, class: "w-full bg-zinc-950 border border-zinc-800 rounded-2xl px-5 py-4 text-zinc-100 font-bold focus:border-indigo-500 outline-none transition-all tabular-nums", required: true %>
        </div>
        <div class="space-y-2">
          <%= f.label :installments_count, "Total de Parcelas", class: "text-[10px] font-bold text-zinc-500 uppercase tracking-widest ml-1" %>
          <%= f.number_field :installments_count, class: "w-full bg-zinc-950 border border-zinc-800 rounded-2xl px-5 py-4 text-zinc-100 font-bold focus:border-indigo-500 outline-none transition-all", required: true %>
        </div>
      </div>

      <div class="space-y-2">
        <%= f.label :remaining_installments, "Parcelas Restantes", class: "text-[10px] font-bold text-zinc-500 uppercase tracking-widest ml-1" %>
        <%= f.number_field :remaining_installments, class: "w-full bg-zinc-950 border border-zinc-800 rounded-2xl px-5 py-4 text-zinc-100 font-bold focus:border-indigo-500 outline-none transition-all", required: true %>
      </div>
    </div>

    <div class="flex flex-col sm:flex-row gap-4 pt-4">
      <%= link_to "Cancelar", dashboard_debts_path, class: "flex-1 text-center bg-zinc-900 hover:bg-zinc-800 text-zinc-500 font-bold py-4 rounded-2xl border border-zinc-800 transition-all" %>
      <%= f.submit "Salvar Dívida", class: "flex-1 bg-indigo-600 hover:bg-indigo-500 text-white font-bold py-4 rounded-2xl transition-all shadow-xl shadow-indigo-500/25 cursor-pointer" %>
    </div>

    <div class="pt-8 border-t border-zinc-800/60 mt-8 flex justify-center">
      <%= button_to dashboard_debt_path(@debt), method: :delete, class: "text-red-500/60 hover:text-red-400 text-[10px] font-bold uppercase tracking-[0.2em] transition-colors", data: { turbo_confirm: "Excluir esta dívida permanentemente?" } do %>
        Excluir Dívida
      <% end %>
    </div>
  <% end %>
</div>
