<%= render "shared/page_header", title: "Minhas Dívidas", subtitle: "Gerencie seus compromissos e planeje a quitação.", action: "Nova Dívida", action_path: new_dashboard_debt_path %>

<div class="bg-zinc-900/40 border border-zinc-800/60 rounded-3xl overflow-hidden backdrop-blur-xl">
  <div class="overflow-x-auto">
    <table class="w-full text-left border-collapse">
      <thead>
        <tr class="bg-zinc-900/80 border-b border-zinc-800/60">
          <th class="px-6 py-4 text-[10px] font-bold text-zinc-500 uppercase tracking-widest">Dívida / Compromisso</th>
          <th class="px-6 py-4 text-[10px] font-bold text-zinc-500 uppercase tracking-widest text-right">Valor Total</th>
          <th class="px-6 py-4 text-[10px] font-bold text-zinc-500 uppercase tracking-widest text-right">Parcela Mensal</th>
          <th class="px-6 py-4 text-[10px] font-bold text-zinc-500 uppercase tracking-widest text-center">Progresso</th>
          <% if current_user.monthly_salary&.positive? %>
            <th class="px-6 py-4 text-[10px] font-bold text-zinc-500 uppercase tracking-widest text-right">Impacto (DTI)</th>
          <% end %>
          <th class="px-6 py-4 text-[10px] font-bold text-zinc-500 uppercase tracking-widest text-center">Ações</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-zinc-800/60">
        <% @debts.each do |debt| %>
          <tr class="hover:bg-zinc-800/40 transition-colors group">
            <td class="px-6 py-5">
              <p class="text-sm font-bold text-zinc-100"><%= debt.name %></p>
              <p class="text-[10px] text-zinc-500 font-bold uppercase tracking-tighter"><%= debt.remaining_installments %> de <%= debt.installments_count %> parcelas restantes</p>
            </td>
            <td class="px-6 py-5 text-right text-sm font-medium text-zinc-400 tabular-nums">
              <%= number_to_currency(debt.total_amount / 100.0, unit: "R$ ") %>
            </td>
            <td class="px-6 py-5 text-right text-sm font-black text-zinc-100 tabular-nums">
              <%= number_to_currency(debt.monthly_payment / 100.0, unit: "R$ ") %>
            </td>
            <td class="px-6 py-5">
              <div class="flex flex-col items-center gap-1.5 min-w-[100px]">
                <div class="w-full h-1.5 bg-zinc-950 rounded-full overflow-hidden border border-zinc-800/50">
                  <div class="h-full bg-indigo-500 rounded-full transition-all duration-1000" style="width: <%= debt.progress_pct %>%"></div>
                </div>
                <span class="text-[9px] font-black text-zinc-600 uppercase tabular-nums"><%= number_to_percentage(debt.progress_pct, precision: 0) %> pago</span>
              </div>
            </td>
            <% if current_user.monthly_salary&.positive? %>
              <td class="px-6 py-5 text-right whitespace-nowrap">
                <% dti = (debt.monthly_payment.to_f / current_user.monthly_salary) * 100 %>
                <span class="text-xs font-bold <%= dti > 15 ? 'text-amber-400' : 'text-zinc-400' %>">
                  <%= number_to_percentage(dti, precision: 1) %>
                </span>
              </td>
            <% end %>
            <td class="px-6 py-5">
              <div class="flex justify-center gap-1 opacity-0 group-hover:opacity-100 transition-opacity">
                <%= link_to edit_dashboard_debt_path(debt), class: "p-2 text-zinc-500 hover:text-zinc-100 bg-zinc-800/40 hover:bg-zinc-800 rounded-xl transition-all" do %>
                  <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" stroke-width="2"/></svg>
                <% end %>
              </div>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>

  <% if @debts.empty? %>
    <div class="py-20 text-center">
      <div class="w-16 h-16 bg-zinc-800/40 rounded-3xl flex items-center justify-center mx-auto mb-4 text-zinc-600 text-3xl">
        💸
      </div>
      <p class="text-zinc-500 text-sm font-medium mb-6">Nenhuma dívida ou parcelamento registrado.</p>
      <%= link_to new_dashboard_debt_path, class: "bg-indigo-600 hover:bg-indigo-500 text-white font-bold py-3 px-6 rounded-xl transition-all shadow-lg shadow-indigo-500/25 inline-flex items-center gap-2 text-xs uppercase tracking-widest" do %>
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path d="M12 4v16m8-8H4" stroke-linecap="round" stroke-linejoin="round"/></svg>
        Registrar Dívida
      <% end %>
    </div>
  <% end %>
</div>
