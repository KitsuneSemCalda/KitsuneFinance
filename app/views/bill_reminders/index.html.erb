<div class="flex flex-col md:flex-row justify-between items-start md:items-center mb-8 gap-4">
  <div>
    <h2 class="text-2xl font-bold text-zinc-100">Contas a Pagar</h2>
    <p class="text-zinc-500 text-sm">Gerencie suas contas fixas e variáveis do mês.</p>
  </div>
  <div class="flex items-center gap-3">
    <%= link_to new_dashboard_bill_reminder_path, class: "bg-indigo-600 hover:bg-indigo-500 text-white font-bold py-2.5 px-5 rounded-xl transition-all shadow-lg shadow-indigo-500/25 flex items-center gap-2 text-xs uppercase tracking-widest" do %>
      <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path d="M12 4v16m8-8H4" stroke-width="2"/></svg>
      Nova Conta
    <% end %>
  </div>
</div>

<%# Summary Cards %>
<div class="grid grid-cols-1 sm:grid-cols-3 gap-4 mb-6">
  <div class="rounded-2xl bg-zinc-900/60 border border-zinc-800/60 p-5">
    <p class="text-xs text-zinc-500 uppercase tracking-wider mb-1">Total a Pagar</p>
    <p class="text-2xl font-bold text-zinc-100"><%= number_to_currency(@total_pending / 100.0, unit: "R$ ", separator: ",", delimiter: ".") %></p>
  </div>
  <div class="rounded-2xl bg-zinc-900/60 border border-zinc-800/60 p-5">
    <p class="text-xs text-zinc-500 uppercase tracking-wider mb-1">Total Pago</p>
    <p class="text-2xl font-bold text-emerald-400"><%= number_to_currency(@total_paid / 100.0, unit: "R$ ", separator: ",", delimiter: ".") %></p>
  </div>
  <div class="rounded-2xl bg-zinc-900/60 border border-zinc-800/60 p-5">
    <p class="text-xs text-zinc-500 uppercase tracking-wider mb-1">Vencidas</p>
    <p class="text-2xl font-bold text-red-400"><%= @overdue.count %></p>
  </div>
</div>

<%# Overdue Bills %>
<% if @overdue.any? %>
  <div class="mb-6">
    <h3 class="text-sm font-bold text-red-400 mb-3 flex items-center gap-2">
      <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/>
      </svg>
      Contas Vencidas
    </h3>
    <div class="space-y-2">
      <% @overdue.each do |bill| %>
        <%= render "bill_reminder_row", bill: bill %>
      <% end %>
    </div>
  </div>
<% end %>

<%# This Month Bills %>
<h3 class="text-sm font-bold text-zinc-200 mb-3">
  <%= t("date.month_names")[Date.today.month] %> — <%= Date.today.year %>
</h3>

<% if @bill_reminders.any? || @upcoming.any? %>
  <div class="space-y-2">
    <% (@bill_reminders + @upcoming).uniq { |b| b.id }.each do |bill| %>
      <%= render "bill_reminder_row", bill: bill %>
    <% end %>
  </div>
<% else %>
  <div class="bg-zinc-900/40 border border-zinc-800/60 rounded-3xl p-12 text-center">
    <div class="w-16 h-16 bg-zinc-800/40 rounded-3xl flex items-center justify-center mx-auto mb-4">
      <svg class="w-8 h-8 text-zinc-600" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2" stroke-width="2"/></svg>
    </div>
    <p class="text-zinc-300 font-bold text-lg">Nenhuma conta cadastrada</p>
    <p class="text-zinc-500 text-sm mt-1">Adicione suas contas fixas para acompanhar os vencimentos.</p>
  </div>
<% end %>
