<div class="bill-row-<%= bill.id %> flex items-center gap-4 bg-zinc-900/40 border border-zinc-800/60 rounded-2xl px-5 py-4 hover:bg-zinc-800/40 transition-all group <%= 'opacity-50' if bill.paid %>">
  <label class="flex items-center cursor-pointer">
    <input type="checkbox" data-bill-id="<%= bill.id %>" class="bill-paid-checkbox w-5 h-5 rounded-lg bg-zinc-800 border-zinc-700 text-indigo-500 focus:ring-indigo-500" <%= 'checked' if bill.paid %>>
  </label>
  <div class="flex-1 min-w-0">
    <p class="text-sm font-bold text-zinc-100 <%= 'line-through' if bill.paid %>"><%= bill.name %></p>
    <p class="text-xs text-zinc-500">
      Vence <%= l(bill.due_date, format: "%d de %B") %>
      <% if bill.recurrent %>
        · <span class="text-indigo-400">Recorrente</span>
      <% end %>
      <% if bill.category %>
        · <%= bill.category.icon %> <%= bill.category.name %>
      <% end %>
    </p>
  </div>
  <div class="text-right shrink-0">
    <p class="text-sm font-black tabular-nums <%= bill.paid ? 'text-zinc-600' : 'text-red-400' %>">
      <%= number_to_currency(bill.amount / 100.0) %>
    </p>
  </div>
  <div class="flex gap-1 opacity-0 group-hover:opacity-100 transition-opacity shrink-0">
    <%= link_to edit_dashboard_bill_reminder_path(bill), class: "p-2 text-zinc-500 hover:text-zinc-100 bg-zinc-800/40 hover:bg-zinc-800 rounded-xl transition-all" do %>
      <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" stroke-width="2"/></svg>
    <% end %>
    <%= button_to dashboard_bill_reminder_path(bill), method: :delete, class: "p-2 text-zinc-500 hover:text-red-400 bg-zinc-800/40 hover:bg-zinc-800 rounded-xl transition-all", data: { turbo_confirm: "Excluir esta conta?" } do %>
      <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" stroke-width="2"/></svg>
    <% end %>
  </div>
</div>
