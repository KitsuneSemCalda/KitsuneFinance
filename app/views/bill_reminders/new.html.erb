<div class="max-w-2xl mx-auto">
  <div class="mb-8">
    <h2 class="text-2xl font-bold text-zinc-100">Nova Conta a Pagar</h2>
    <p class="text-zinc-500 text-sm">Registre uma conta fixa ou variável para acompanhar os vencimentos.</p>
  </div>

  <%= form_with model: [:dashboard, @bill_reminder], class: "space-y-6" do |f| %>
    <div class="bg-zinc-900/60 border border-zinc-800/60 rounded-3xl p-8 space-y-8">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <div class="space-y-2">
          <%= f.label :name, "Nome da Conta", class: "text-[10px] font-bold text-zinc-500 uppercase tracking-widest ml-1" %>
          <%= f.text_field :name, placeholder: "Ex: Aluguel, Internet, Netflix...", class: "w-full bg-zinc-950 border border-zinc-800 rounded-2xl px-5 py-4 text-zinc-100 font-bold focus:border-indigo-500 outline-none transition-all placeholder:text-zinc-700", required: true %>
        </div>
        <div class="space-y-2">
          <%= f.label :amount, "Valor (R$)", class: "text-[10px] font-bold text-zinc-500 uppercase tracking-widest ml-1" %>
          <%= f.number_field :amount, step: 0.01, class: "w-full bg-zinc-950 border border-zinc-800 rounded-2xl px-5 py-4 text-zinc-100 font-bold focus:border-indigo-500 outline-none transition-all", required: true %>
        </div>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <div class="space-y-2">
          <%= f.label :due_date, "Data de Vencimento", class: "text-[10px] font-bold text-zinc-500 uppercase tracking-widest ml-1" %>
          <%= f.date_field :due_date, class: "w-full bg-zinc-950 border border-zinc-800 rounded-2xl px-5 py-4 text-zinc-100 font-bold focus:border-indigo-500 outline-none transition-all" %>
        </div>
        <div class="space-y-2">
          <%= f.label :category_id, "Categoria", class: "text-[10px] font-bold text-zinc-500 uppercase tracking-widest ml-1" %>
          <%= f.collection_select :category_id, current_user.categories, :id, :name, { prompt: "Selecione" }, class: "w-full bg-zinc-950 border border-zinc-800 rounded-2xl px-5 py-4 text-zinc-100 font-bold focus:border-indigo-500 outline-none transition-all" %>
        </div>
      </div>

      <div class="flex items-center gap-6">
        <div class="flex items-center gap-3">
          <%= f.check_box :recurrent, class: "w-5 h-5 rounded-lg bg-zinc-800 border-zinc-700 text-indigo-500 focus:ring-indigo-500" %>
          <%= f.label :recurrent, "Conta Recorrente", class: "text-sm text-zinc-300 font-medium" %>
        </div>
        <div class="space-y-2">
          <%= f.label :recurrence_period, "Período", class: "text-[10px] font-bold text-zinc-500 uppercase tracking-widest ml-1" %>
          <%= f.select :recurrence_period, [["Mensal", "monthly"], ["Semanal", "weekly"], ["Anual", "yearly"]], { include_blank: "Não recorrente" }, class: "bg-zinc-950 border border-zinc-800 rounded-xl px-4 py-2.5 text-sm text-zinc-100 focus:border-indigo-500 outline-none transition-all" %>
        </div>
      </div>

      <div class="space-y-2">
        <%= f.label :notes, "Observações", class: "text-[10px] font-bold text-zinc-500 uppercase tracking-widest ml-1" %>
        <%= f.text_area :notes, rows: 2, placeholder: "Detalhes adicionais...", class: "w-full bg-zinc-950 border border-zinc-800 rounded-2xl px-5 py-4 text-zinc-200 text-sm focus:border-indigo-500 outline-none transition-all placeholder:text-zinc-700" %>
      </div>
    </div>

    <div class="flex justify-end gap-4">
      <%= link_to "Cancelar", dashboard_bill_reminders_path, class: "bg-zinc-900 hover:bg-zinc-800 text-zinc-500 font-bold py-4 px-8 rounded-2xl border border-zinc-800 transition-all" %>
      <%= f.submit "Salvar Conta", class: "bg-indigo-600 hover:bg-indigo-500 text-white font-bold py-4 px-8 rounded-2xl transition-all shadow-xl shadow-indigo-500/25 cursor-pointer" %>
    </div>
  <% end %>
</div>
