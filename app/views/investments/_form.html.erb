<div class="max-w-2xl mx-auto bg-zinc-900/60 border border-zinc-800/60 rounded-3xl p-8 shadow-2xl">
  <h2 class="text-2xl font-bold text-zinc-100 mb-8"><%= @page_title %></h2>

  <%= form_with model: [:dashboard, @investment], class: "space-y-6" do |f| %>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      <div class="space-y-2">
        <%= f.label :ticker, "Ticker / ID", class: "text-xs font-bold text-zinc-500 uppercase tracking-wider" %>
        <%= f.text_field :ticker, placeholder: "Ex: PETR4, BTC, AAPL", class: "w-full bg-zinc-950 border border-zinc-800 rounded-xl px-4 py-3 text-zinc-100 focus:border-indigo-500 outline-none transition-all" %>
      </div>

      <div class="space-y-2">
        <%= f.label :quantity, "Quantidade", class: "text-xs font-bold text-zinc-500 uppercase tracking-wider" %>
        <%= f.number_field :quantity, step: 1, value: @investment.quantity.to_i, class: "w-full bg-zinc-950 border border-zinc-800 rounded-xl px-4 py-3 text-zinc-100 focus:border-indigo-500 outline-none transition-all" %>
      </div>
    </div>

    <div class="space-y-2">
      <%= f.label :name, "Nome do Ativo", class: "text-xs font-bold text-zinc-500 uppercase tracking-wider" %>
      <%= f.text_field :name, placeholder: "Ex: Petrobras PN", class: "w-full bg-zinc-950 border border-zinc-800 rounded-xl px-4 py-3 text-zinc-100 focus:border-indigo-500 outline-none transition-all" %>
    </div>
    
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      <div class="space-y-2">
        <%= f.label :asset_type, "Tipo de Ativo", class: "text-xs font-bold text-zinc-500 uppercase tracking-wider" %>
        <%= f.select :asset_type, [["Ação BR", "stock_br"], ["FII", "fii"], ["Renda Fixa", "fixed_income"], ["Tesouro Direto BR", "treasury_br"], ["Tesouro Direto Internacional", "treasury_intl"], ["Internacional", "international"], ["Cripto", "crypto"], ["Outros", "other"]], {}, class: "w-full bg-zinc-950 border border-zinc-800 rounded-xl px-4 py-3 text-zinc-100 focus:border-indigo-500 outline-none transition-all" %>
      </div>

      <div class="space-y-2">
        <%= f.label :avg_price, "Preço Médio (R$) — deixe vazio se for usar Operações", class: "text-xs font-bold text-zinc-500 uppercase tracking-wider" %>
        <%= f.number_field :avg_price, step: 0.01, value: number_to_human(f.object.avg_price.to_f / 100, precision: 4), class: "w-full bg-zinc-950 border border-zinc-800 rounded-xl px-4 py-3 text-zinc-100 focus:border-indigo-500 outline-none transition-all" %>
      </div>
    </div>

    <div class="space-y-2">
      <%= f.label :current_price, "Preço Atual (R$) — opcional, deixe vazio para buscar automático", class: "text-xs font-bold text-zinc-500 uppercase tracking-wider" %>
      <%= f.number_field :current_price, step: 0.01, value: number_to_human(f.object.current_price.to_f / 100, precision: 4), class: "w-full bg-zinc-950 border border-zinc-800 rounded-xl px-4 py-3 text-zinc-100 focus:border-indigo-500 outline-none transition-all" %>
    </div>

    <div class="space-y-2">
      <%= f.label :price_feed_url, "Feed de Preço (URL) — RSS/Atom/JSON/CSV, opcional", class: "text-xs font-bold text-zinc-500 uppercase tracking-wider" %>
      <%= f.url_field :price_feed_url, placeholder: "https://...", class: "w-full bg-zinc-950 border border-zinc-800 rounded-xl px-4 py-3 text-zinc-100 focus:border-indigo-500 outline-none transition-all" %>
    </div>

    <div class="flex gap-4 pt-4">
      <%= link_to "Cancelar", dashboard_investments_path, class: "flex-1 text-center bg-zinc-800 hover:bg-zinc-700 text-zinc-300 font-medium py-3 rounded-xl transition-all" %>
      <%= f.submit "Salvar Ativo", class: "flex-1 bg-indigo-600 hover:bg-indigo-500 text-white font-medium py-3 rounded-xl transition-all shadow-lg shadow-indigo-500/25 cursor-pointer" %>
    </div>
  <% end %>
</div>
