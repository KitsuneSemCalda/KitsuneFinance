<div class="flex flex-col md:flex-row justify-between items-start md:items-center mb-8 gap-4">
  <div>
    <h2 class="text-2xl font-bold text-zinc-100">Ativos em Carteira</h2>
    <p class="text-zinc-500 text-sm"><%= @investments.count %> ativo(s) na carteira</p>
  </div>
  <div class="flex gap-3">
    <%= link_to dashboard_investments_path, class: "bg-zinc-800 hover:bg-zinc-700 text-zinc-300 font-medium py-2.5 px-5 rounded-xl transition-all flex items-center gap-2 border border-zinc-700/50" do %>
      <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path d="M3 10h18M3 14h18m-9-4v8m-7 0h14a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z" stroke-width="2"/></svg>
      Visão em Tabela
    <% end %>
    <%= link_to new_dashboard_investment_path, class: "bg-indigo-600 hover:bg-indigo-500 text-white font-medium py-2.5 px-5 rounded-xl transition-all shadow-lg shadow-indigo-500/25 flex items-center gap-2 group" do %>
      <svg class="w-4 h-4 group-hover:rotate-90 transition-transform duration-300" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path d="M12 4v16m8-8H4" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
      Novo Ativo
    <% end %>
  </div>
</div>

<div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-6">
  <% @investments.each do |inv| %>
    <% type_labels = { "stock_br" => "Ação BR", "fii" => "FII", "fixed_income" => "Renda Fixa", "treasury_br" => "Tesouro BR", "treasury_intl" => "Tesouro Intl", "international" => "Internacional", "crypto" => "Cripto", "other" => "Outros" } %>
    <% type_colors = { "stock_br" => "indigo", "fii" => "sky", "fixed_income" => "emerald", "crypto" => "orange", "international" => "amber" } %>
    <% color = type_colors[inv.asset_type] || "zinc" %>

    <div class="bg-zinc-900/60 border border-zinc-800/60 rounded-3xl p-6 hover:border-zinc-700/60 transition-all hover-lift" data-investment-id="<%= inv.id %>">
      <%# Card Header %>
      <div class="flex items-start justify-between mb-5">
        <div class="flex items-center gap-3 min-w-0">
          <div class="w-12 h-12 rounded-2xl bg-gradient-to-br from-zinc-800 to-zinc-900 border border-zinc-700/50 flex items-center justify-center font-bold text-sm text-zinc-300 flex-shrink-0">
            <%= inv.ticker.first(2).upcase %>
          </div>
          <div class="min-w-0">
            <h3 class="text-base font-bold text-zinc-100 truncate"><%= inv.ticker.presence || inv.name %></h3>
            <p class="text-xs text-zinc-500 truncate"><%= inv.name %></p>
          </div>
        </div>
        <span class="inline-block text-[9px] font-bold text-<%= color %>-400 bg-<%= color %>-500/10 border border-<%= color %>-500/20 px-2.5 py-1 rounded-full uppercase tracking-wider flex-shrink-0">
          <%= type_labels[inv.asset_type] || inv.asset_type.humanize %>
        </span>
      </div>

      <%# Price & Quantity Grid %>
      <div class="grid grid-cols-2 gap-4 mb-5 p-4 bg-zinc-950/40 border border-zinc-800/40 rounded-2xl">
        <div>
          <span class="text-[9px] font-bold text-zinc-500 uppercase tracking-widest">Quantidade</span>
          <p class="text-lg font-bold text-zinc-100 tabular-nums mt-1">
            <span class="inline-edit cursor-pointer hover:text-indigo-400 transition-colors"
                  data-investment-id="<%= inv.id %>"
                  data-field="quantity"
                  data-value="<%= inv.quantity %>">
              <%= number_with_delimiter(inv.quantity, separator: ",", delimiter: ".") %>
            </span>
          </p>
        </div>
        <div class="text-right">
          <span class="text-[9px] font-bold text-zinc-500 uppercase tracking-widest">Preço Médio</span>
          <p class="text-lg font-bold text-zinc-100 tabular-nums mt-1">
            <% if inv.avg_price > 0 %>
              <%= number_to_currency(inv.avg_price / 100.0) %>
            <% else %>
              <span class="text-zinc-600">—</span>
            <% end %>
          </p>
        </div>
        <div>
          <span class="text-[9px] font-bold text-zinc-500 uppercase tracking-widest">Preço Atual</span>
          <p class="text-lg font-bold text-zinc-100 tabular-nums mt-1">
            <span class="inline-edit cursor-pointer hover:text-indigo-400 transition-colors"
                  data-investment-id="<%= inv.id %>"
                  data-field="current_price"
                  data-currency="true"
                  data-value="<%= '%.4f' % (inv.current_price / 100.0) %>">
              <%= number_to_currency(inv.current_price / 100.0) %>
            </span>
          </p>
        </div>
        <div class="text-right">
          <span class="text-[9px] font-bold text-zinc-500 uppercase tracking-widest">Total</span>
          <p class="text-lg font-bold text-zinc-100 tabular-nums mt-1">
            <%= number_to_currency(inv.current_value / 100.0) %>
          </p>
        </div>
      </div>

      <%# Gain/Loss Bar %>
      <% if inv.avg_price > 0 && inv.current_price > 0 %>
        <div class="mb-5">
          <div class="flex items-center justify-between text-sm mb-1.5">
            <span class="text-xs text-zinc-500">Ganho/Perda</span>
            <span class="text-sm font-bold <%= inv.gain_loss >= 0 ? 'text-emerald-400' : 'text-red-400' %>">
              <%= inv.gain_loss >= 0 ? '+' : '' %><%= number_to_currency(inv.gain_loss / 100.0) %>
              (<%= inv.gain_loss >= 0 ? '+' : '' %><%= number_to_percentage(inv.gain_loss_pct, precision: 2) %>)
            </span>
          </div>
          <div class="w-full h-1.5 bg-zinc-800 rounded-full overflow-hidden">
            <% pct = [inv.gain_loss_pct.abs / 100, 1].min %>
            <div class="h-full rounded-full transition-all <%= inv.gain_loss >= 0 ? 'bg-emerald-500' : 'bg-red-500' %>" style="width: <%= pct * 100 %>%"></div>
          </div>
        </div>
      <% end %>

      <%# Actions %>
      <div class="flex items-center justify-between pt-1 border-t border-zinc-800/40">
        <div class="flex items-center gap-2">
          <button class="quick-trade-btn px-4 py-2 bg-emerald-500/10 hover:bg-emerald-500/20 text-emerald-400 text-[10px] font-bold uppercase rounded-xl transition-all"
                  data-investment-id="<%= inv.id %>"
                  data-ticker="<%= inv.ticker %>"
                  data-trade-type="buy">
            Comprar
          </button>
          <button class="quick-trade-btn px-4 py-2 bg-red-500/10 hover:bg-red-500/20 text-red-400 text-[10px] font-bold uppercase rounded-xl transition-all"
                  data-investment-id="<%= inv.id %>"
                  data-ticker="<%= inv.ticker %>"
                  data-trade-type="sell">
            Vender
          </button>
        </div>
        <div class="flex items-center gap-1">
          <%= button_to refresh_price_dashboard_investment_path(inv), method: :post, class: "p-2 text-zinc-500 hover:text-sky-400 rounded-lg hover:bg-sky-500/10 transition-all", title: "Atualizar Preço" do %>
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15" stroke-width="2"/></svg>
          <% end %>
          <%= link_to dashboard_investment_trades_path(inv), class: "p-2 text-zinc-500 hover:text-amber-400 rounded-lg hover:bg-amber-500/10 transition-all", title: "Operações" do %>
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2" stroke-width="1.5"/></svg>
          <% end %>
          <%= link_to edit_dashboard_investment_path(inv), class: "p-2 text-zinc-500 hover:text-zinc-100 rounded-lg hover:bg-zinc-700 transition-all", title: "Editar" do %>
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" stroke-width="1.5"/></svg>
          <% end %>
          <%= button_to dashboard_investment_path(inv), method: :delete, class: "p-2 text-zinc-500 hover:text-red-400 rounded-lg hover:bg-red-500/10 transition-all", title: "Excluir", data: { turbo_confirm: "Tem certeza?" } do %>
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" stroke-width="1.5"/></svg>
          <% end %>
        </div>
      </div>
    </div>
  <% end %>
</div>

<% if @investments.empty? %>
  <div class="flex flex-col items-center justify-center py-24 text-center">
    <div class="w-20 h-20 bg-zinc-800/40 rounded-3xl flex items-center justify-center mb-6">
      <svg class="w-10 h-10 text-zinc-600" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10" stroke-width="2"/></svg>
    </div>
    <h3 class="text-xl font-bold text-zinc-300">Sua carteira está vazia</h3>
    <p class="text-zinc-500 text-sm max-w-xs mx-auto mt-2">Comece a adicionar seus ativos para acompanhar sua evolução patrimonial.</p>
    <%= link_to "Adicionar primeiro ativo", new_dashboard_investment_path, class: "mt-8 bg-indigo-600 hover:bg-indigo-500 text-white font-bold py-3 px-8 rounded-2xl transition-all shadow-xl shadow-indigo-500/20" %>
  </div>
<% end %>
