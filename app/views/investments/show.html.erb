<div class="flex justify-between items-center mb-8">
  <div>
    <h2 class="text-2xl font-bold text-zinc-100"><%= @investment.ticker %></h2>
    <p class="text-zinc-500 text-sm"><%= @investment.name %> · <%= @investment.asset_type.humanize %></p>
  </div>
  <div class="flex gap-3">
    <%= link_to edit_dashboard_investment_path(@investment), class: "bg-zinc-800 hover:bg-zinc-700 text-zinc-300 font-medium py-2 px-4 rounded-xl transition-all" do %>
      Editar
    <% end %>
    <%= link_to dashboard_investments_path, class: "bg-zinc-800 hover:bg-zinc-700 text-zinc-300 font-medium py-2 px-4 rounded-xl transition-all" do %>
      Voltar
    <% end %>
  </div>
</div>

<div class="grid grid-cols-1 md:grid-cols-4 gap-6 mb-8">
  <div class="bg-zinc-900/60 border border-zinc-800/60 rounded-2xl p-6">
    <span class="text-xs text-zinc-500 uppercase tracking-wider block mb-1">Quantidade</span>
    <p class="text-2xl font-bold text-zinc-100"><%= @investment.quantity.to_i %></p>
  </div>
  <div class="bg-zinc-900/60 border border-zinc-800/60 rounded-2xl p-6">
    <span class="text-xs text-zinc-500 uppercase tracking-wider block mb-1">P. Médio</span>
    <p class="text-2xl font-bold text-zinc-100"><%= number_to_currency(@investment.avg_price / 100.0, unit: "R$ ", separator: ",", delimiter: ".") %></p>
  </div>
  <div class="bg-zinc-900/60 border border-zinc-800/60 rounded-2xl p-6">
    <span class="text-xs text-zinc-500 uppercase tracking-wider block mb-1">P. Atual</span>
    <p class="text-2xl font-bold text-zinc-100"><%= number_to_currency(@investment.current_price / 100.0, unit: "R$ ", separator: ",", delimiter: ".") %></p>
  </div>
  <div class="bg-zinc-900/60 border border-zinc-800/60 rounded-2xl p-6">
    <span class="text-xs text-zinc-500 uppercase tracking-wider block mb-1">Total</span>
    <p class="text-2xl font-bold text-zinc-100"><%= number_to_currency(@investment.current_value / 100.0, unit: "R$ ", separator: ",", delimiter: ".") %></p>
  </div>
</div>

<div class="flex items-center justify-between mb-4">
  <h3 class="text-lg font-semibold text-zinc-200">Operações</h3>
  <%= link_to dashboard_investment_trades_path(@investment), class: "text-sm text-indigo-400 hover:text-indigo-300 transition-colors" do %>
    Gerenciar Operaçōes →
  <% end %>
</div>

<div class="bg-zinc-900/40 border border-zinc-800/60 rounded-2xl overflow-hidden backdrop-blur-xl">
  <table class="w-full text-left">
    <thead>
      <tr class="bg-zinc-900/60 border-b border-zinc-800/60">
        <th class="px-6 py-4 text-xs font-semibold text-zinc-500 uppercase tracking-wider">Data</th>
        <th class="px-6 py-4 text-xs font-semibold text-zinc-500 uppercase tracking-wider">Tipo</th>
        <th class="px-6 py-4 text-xs font-semibold text-zinc-500 uppercase tracking-wider text-right">Quantidade</th>
        <th class="px-6 py-4 text-xs font-semibold text-zinc-500 uppercase tracking-wider text-right">Preço</th>
        <th class="px-6 py-4 text-xs font-semibold text-zinc-500 uppercase tracking-wider text-right">Total</th>
      </tr>
    </thead>
    <tbody class="divide-y divide-zinc-800/60">
      <% @trades.each do |trade| %>
        <tr class="hover:bg-zinc-800/40 transition-colors">
          <td class="px-6 py-4 text-sm text-zinc-100"><%= l(trade.date, format: :default) %></td>
          <td class="px-6 py-4">
            <span class="text-xs font-semibold <%= trade.trade_type == 'buy' ? 'text-emerald-400' : 'text-red-400' %>">
              <%= trade.trade_type == "buy" ? "Compra" : "Venda" %>
            </span>
          </td>
          <td class="px-6 py-4 text-right text-sm text-zinc-100"><%= trade.quantity.to_i %></td>
          <td class="px-6 py-4 text-right text-sm text-zinc-100"><%= number_to_currency(trade.price / 100.0, unit: "R$ ", separator: ",", delimiter: ".") %></td>
          <td class="px-6 py-4 text-right text-sm text-zinc-100"><%= number_to_currency(trade.quantity * trade.price / 100.0, unit: "R$ ", separator: ",", delimiter: ".") %></td>
        </tr>
      <% end %>
      <% if @trades.empty? %>
        <tr>
          <td colspan="5" class="px-6 py-12 text-center text-zinc-600 text-sm">
            Nenhuma operação registrada.
            <%= link_to "Adicionar", dashboard_investment_trades_path(@investment), class: "text-indigo-400 hover:text-indigo-300" %>.
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>
