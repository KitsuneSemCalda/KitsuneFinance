<div class="flex flex-col md:flex-row justify-between items-start md:items-center mb-8 gap-4">
  <div class="flex items-center gap-4">
    <%= link_to dashboard_investments_path, class: "w-10 h-10 rounded-xl bg-zinc-900 border border-zinc-800 flex items-center justify-center text-zinc-500 hover:text-zinc-100 hover:border-zinc-700 transition-all shadow-sm" do %>
      <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path d="M15 19l-7-7 7-7" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
    <% end %>
    <div>
      <h2 class="text-2xl font-bold text-zinc-100"><%= @investment.ticker %></h2>
      <p class="text-zinc-500 text-sm"><%= @investment.name %></p>
    </div>
  </div>
  <div class="flex gap-3">
    <%= button_to clear_dashboard_investment_trades_path(@investment), method: :delete,
        class: "bg-red-500/10 hover:bg-red-500/20 text-red-400 font-bold py-2.5 px-5 rounded-xl transition-all border border-red-500/20 text-xs uppercase tracking-widest",
        data: { turbo_confirm: "Tem certeza que deseja remover TODO o histórico desta operação? Esta ação é irreversível." } do %>
      Limpar Histórico
    <% end %>
  </div>
</div>

<%# ── STATS ROW ── %>
<div class="grid grid-cols-1 sm:grid-cols-3 gap-6 mb-10">
  <div class="bg-zinc-900/60 border border-zinc-800/60 rounded-3xl p-6">
    <span class="text-[10px] font-bold uppercase tracking-widest text-zinc-500 block mb-2">Quantidade Acumulada</span>
    <p class="text-3xl font-black text-zinc-100 tabular-nums"><%= number_with_delimiter(@investment.quantity) %></p>
  </div>
  <div class="bg-zinc-900/60 border border-zinc-800/60 rounded-3xl p-6">
    <span class="text-[10px] font-bold uppercase tracking-widest text-zinc-500 block mb-2">Preço Médio de Compra</span>
    <p class="text-3xl font-black text-zinc-100 tabular-nums"><%= number_to_currency(@investment.avg_price / 100.0, unit: "R$ ", separator: ",", delimiter: ".") %></p>
  </div>
  <div class="bg-zinc-900/60 border border-zinc-800/60 rounded-3xl p-6">
    <span class="text-[10px] font-bold uppercase tracking-widest text-zinc-500 block mb-2">Total Investido</span>
    <p class="text-3xl font-black text-indigo-400 tabular-nums"><%= number_to_currency(@investment.total_cost / 100.0, unit: "R$ ", separator: ",", delimiter: ".") %></p>
  </div>
</div>

<div class="grid grid-cols-1 xl:grid-cols-3 gap-8">
  
  <%# ── NEW TRADE FORM ── %>
  <div class="xl:col-span-1">
    <div class="bg-zinc-900/60 border border-zinc-800/60 rounded-3xl p-8 sticky top-8 shadow-2xl">
      <h3 class="text-lg font-bold text-zinc-100 mb-8">Registrar Operação</h3>
      
      <%= form_with model: [@investment, Trade.new], url: dashboard_investment_trades_path(@investment), class: "space-y-6" do |f| %>
        <div class="space-y-4">
          <div class="flex bg-zinc-950 p-1 rounded-2xl border border-zinc-800">
            <% [["Compra", "buy"], ["Venda", "sell"]].each do |label, val| %>
              <label class="flex-1 cursor-pointer">
                <%= f.radio_button :trade_type, val, class: "peer sr-only", checked: val == "buy" %>
                <div class="py-3 text-center text-xs font-bold uppercase tracking-widest text-zinc-500 rounded-xl peer-checked:bg-zinc-800 peer-checked:text-zinc-100 transition-all">
                  <%= label %>
                </div>
              </label>
            <% end %>
          </div>

          <div class="grid grid-cols-2 gap-4">
            <div class="space-y-2">
              <%= f.label :quantity, "Qtd", class: "text-[10px] font-bold text-zinc-500 uppercase tracking-widest ml-1" %>
              <%= f.number_field :quantity, step: :any, min: 0.000001, required: true, class: "w-full bg-zinc-950 border border-zinc-800 rounded-xl px-4 py-4 text-zinc-100 font-bold focus:border-indigo-500 outline-none transition-all" %>
            </div>
            <div class="space-y-2">
              <%= f.label :price, "Preço Unit.", class: "text-[10px] font-bold text-zinc-500 uppercase tracking-widest ml-1" %>
              <%= f.number_field :price, step: :any, min: 0, required: true, class: "w-full bg-zinc-950 border border-zinc-800 rounded-xl px-4 py-4 text-zinc-100 font-bold focus:border-indigo-500 outline-none transition-all" %>
            </div>
          </div>

          <div class="space-y-2">
            <%= f.label :date, "Data da Operação", class: "text-[10px] font-bold text-zinc-500 uppercase tracking-widest ml-1" %>
            <%= f.date_field :date, value: Date.today, required: true, class: "w-full bg-zinc-950 border border-zinc-800 rounded-xl px-4 py-4 text-zinc-100 font-bold focus:border-indigo-500 outline-none transition-all" %>
          </div>

          <div class="space-y-2">
            <%= f.label :notes, "Notas", class: "text-[10px] font-bold text-zinc-500 uppercase tracking-widest ml-1" %>
            <%= f.text_area :notes, rows: 2, class: "w-full bg-zinc-950 border border-zinc-800 rounded-xl px-4 py-3 text-zinc-200 text-sm focus:border-indigo-500 outline-none transition-all" %>
          </div>
        </div>

        <%= f.submit "Salvar Operação", class: "w-full bg-indigo-600 hover:bg-indigo-500 text-white font-bold py-4 rounded-2xl transition-all shadow-xl shadow-indigo-500/25 cursor-pointer mt-4" %>
      <% end %>
    </div>
  </div>

  <%# ── TRADES LIST ── %>
  <div class="xl:col-span-2">
    <div class="bg-zinc-900/40 border border-zinc-800/60 rounded-3xl overflow-hidden backdrop-blur-xl">
      <div class="px-6 py-5 border-b border-zinc-800/60 bg-zinc-900/80">
        <h3 class="text-xs font-black text-zinc-400 uppercase tracking-[0.2em]">Histórico de Movimentações</h3>
      </div>

      <%# Desktop Table %>
      <div class="hidden lg:block overflow-x-auto">
        <table class="w-full text-left">
          <thead>
            <tr class="text-[10px] font-bold text-zinc-500 uppercase tracking-[0.2em] border-b border-zinc-800/60">
              <th class="px-6 py-4">Data</th>
              <th class="px-6 py-4">Operação</th>
              <th class="px-6 py-4 text-right">Qtd</th>
              <th class="px-6 py-4 text-right">Preço</th>
              <th class="px-6 py-4 text-right">Total</th>
              <th class="px-6 py-4 text-center">Ações</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-zinc-800/60">
            <% @trades.each do |trade| %>
              <tr class="hover:bg-zinc-800/40 transition-colors group">
                <td class="px-6 py-5 text-sm text-zinc-400 tabular-nums"><%= l(trade.date, format: "%d %b, %Y") %></td>
                <td class="px-6 py-5">
                  <span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full text-[10px] font-black uppercase tracking-wider <%= trade.trade_type == 'buy' ? 'text-emerald-400 bg-emerald-500/10' : 'text-red-400 bg-red-500/10' %>">
                    <%= trade.trade_type == "buy" ? "Compra" : "Venda" %>
                  </span>
                </td>
                <td class="px-6 py-5 text-right text-sm font-medium text-zinc-200 tabular-nums"><%= number_with_delimiter(trade.quantity, separator: ",", delimiter: ".") %></td>
                <td class="px-6 py-5 text-right text-sm text-zinc-400 tabular-nums"><%= number_to_currency(trade.price / 100.0, unit: "R$ ") %></td>
                <td class="px-6 py-5 text-right text-sm font-black text-zinc-100 tabular-nums"><%= number_to_currency(trade.quantity * trade.price / 100.0, unit: "R$ ") %></td>
                <td class="px-6 py-5 text-center">
                  <div class="flex justify-center gap-1 opacity-0 group-hover:opacity-100 transition-opacity">
                    <%= link_to edit_dashboard_investment_trade_path(@investment, trade), class: "p-2 text-zinc-500 hover:text-zinc-100 bg-zinc-800/40 hover:bg-zinc-800 rounded-xl transition-all" do %>
                      <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" stroke-width="2"/></svg>
                    <% end %>
                    <%= button_to dashboard_investment_trade_path(@investment, trade), method: :delete, class: "p-2 text-zinc-500 hover:text-red-400 bg-zinc-800/40 hover:bg-red-500/10 rounded-xl transition-all", data: { turbo_confirm: "Excluir esta operação?" } do %>
                      <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" stroke-width="2"/></svg>
                    <% end %>
                  </div>
                </td>
              </tr>
            <% end %>
            <% if @trades.empty? %>
              <tr>
                <td colspan="6" class="px-6 py-20 text-center">
                  <p class="text-zinc-600 text-sm font-medium">Nenhuma operação registrada para este ativo.</p>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>

      <%# Mobile Cards %>
      <div class="lg:hidden grid grid-cols-1 gap-4 p-4">
        <% @trades.each do |trade| %>
          <div class="bg-zinc-950/40 border border-zinc-800/80 rounded-2xl p-5 space-y-4">
            <div class="flex items-start justify-between">
              <div>
                <p class="text-xs font-bold text-zinc-500 uppercase tracking-widest"><%= l(trade.date, format: "%d %b, %Y") %></p>
                <p class="text-sm font-bold text-zinc-100 mt-1"><%= trade.trade_type == 'buy' ? 'Compra' : 'Venda' %> · <%= number_with_delimiter(trade.quantity) %> un</p>
              </div>
              <p class="text-base font-black text-zinc-100"><%= number_to_currency(trade.quantity * trade.price / 100.0, unit: "R$ ") %></p>
            </div>
            <div class="flex justify-end gap-2 pt-2 border-t border-zinc-800/40">
              <%= link_to "Editar", edit_dashboard_investment_trade_path(@investment, trade), class: "px-3 py-1.5 bg-zinc-800 text-zinc-300 text-[10px] font-bold uppercase rounded-lg border border-zinc-700" %>
              <%= button_to "Excluir", dashboard_investment_trade_path(@investment, trade), method: :delete, class: "px-3 py-1.5 bg-red-500/10 text-red-400 text-[10px] font-bold uppercase rounded-lg border border-red-500/20", data: { turbo_confirm: "Excluir?" } %>
            </div>
          </div>
        <% end %>
      </div>
    </div>
  </div>
</div>
