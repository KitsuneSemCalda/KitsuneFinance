<div class="flex justify-between items-center mb-8">
  <div>
    <h2 class="text-2xl font-bold text-zinc-100">Operações — <%= @investment.ticker %></h2>
    <p class="text-zinc-500 text-sm"><%= @investment.name %></p>
  </div>
  <div class="flex gap-3">
    <%= link_to dashboard_investments_path, class: "bg-zinc-800 hover:bg-zinc-700 text-zinc-300 font-medium py-2 px-4 rounded-xl transition-all flex items-center gap-2" do %>
      Voltar
    <% end %>
    <%= button_to clear_dashboard_investment_trades_path(@investment), method: :delete,
        class: "bg-red-900/50 hover:bg-red-800/60 text-red-300 font-medium py-2 px-4 rounded-xl transition-all flex items-center gap-2",
        data: { turbo_confirm: "Remover todas as operações?" } do %>
      Limpar Tudo
    <% end %>
  </div>
</div>

<div class="grid grid-cols-1 lg:grid-cols-3 gap-6 mb-8">
  <div class="bg-zinc-900/60 border border-zinc-800/60 rounded-2xl p-6">
    <span class="text-xs text-zinc-500 uppercase tracking-wider block mb-1">Quantidade Total</span>
    <p class="text-3xl font-bold text-zinc-100"><%= @investment.quantity.to_i %></p>
  </div>
  <div class="bg-zinc-900/60 border border-zinc-800/60 rounded-2xl p-6">
    <span class="text-xs text-zinc-500 uppercase tracking-wider block mb-1">Preço Médio</span>
    <p class="text-3xl font-bold text-zinc-100"><%= number_to_currency(@investment.avg_price / 100.0, unit: "R$ ", separator: ",", delimiter: ".") %></p>
  </div>
  <div class="bg-zinc-900/60 border border-zinc-800/60 rounded-2xl p-6">
    <span class="text-xs text-zinc-500 uppercase tracking-wider block mb-1">Total Investido</span>
    <p class="text-3xl font-bold text-zinc-100"><%= number_to_currency(@investment.total_cost / 100.0, unit: "R$ ", separator: ",", delimiter: ".") %></p>
  </div>
</div>

<%# New Trade Form %>
<div class="bg-zinc-900/40 border border-zinc-800/60 rounded-2xl p-6 mb-8">
  <h3 class="text-sm font-semibold text-zinc-200 mb-4">Nova Operação</h3>
  <%= form_with model: [@investment, Trade.new], url: dashboard_investment_trades_path(@investment), class: "space-y-4" do |f| %>
    <div class="grid grid-cols-1 md:grid-cols-5 gap-4">
      <div class="space-y-2">
        <%= f.label :trade_type, "Tipo", class: "text-xs font-bold text-zinc-500 uppercase tracking-wider" %>
        <%= f.select :trade_type, [["Compra", "buy"], ["Venda", "sell"]], {},
            class: "w-full bg-zinc-950 border border-zinc-800 rounded-xl px-4 py-3 text-zinc-100 focus:border-indigo-500 outline-none transition-all" %>
      </div>
      <div class="space-y-2">
        <%= f.label :quantity, "Qtd", class: "text-xs font-bold text-zinc-500 uppercase tracking-wider" %>
        <%= f.number_field :quantity, step: 1, min: 0.000001, required: true,
            class: "w-full bg-zinc-950 border border-zinc-800 rounded-xl px-4 py-3 text-zinc-100 focus:border-indigo-500 outline-none transition-all" %>
      </div>
      <div class="space-y-2">
        <%= f.label :price, "Preço (R$)", class: "text-xs font-bold text-zinc-500 uppercase tracking-wider" %>
        <%= f.number_field :price, step: 0.01, min: 0, required: true,
            class: "w-full bg-zinc-950 border border-zinc-800 rounded-xl px-4 py-3 text-zinc-100 focus:border-indigo-500 outline-none transition-all" %>
      </div>
      <div class="space-y-2">
        <%= f.label :date, "Data", class: "text-xs font-bold text-zinc-500 uppercase tracking-wider" %>
        <%= f.date_field :date, value: Date.today, required: true,
            class: "w-full bg-zinc-950 border border-zinc-800 rounded-xl px-4 py-3 text-zinc-100 focus:border-indigo-500 outline-none transition-all" %>
      </div>
      <div class="space-y-2 flex items-end">
        <%= f.submit "Adicionar", class: "w-full bg-indigo-600 hover:bg-indigo-500 text-white font-medium py-3 rounded-xl transition-all shadow-lg shadow-indigo-500/25 cursor-pointer" %>
      </div>
    </div>
  <% end %>
</div>

<%# Trades Table %>
<div class="bg-zinc-900/40 border border-zinc-800/60 rounded-2xl overflow-hidden backdrop-blur-xl">
  <table class="w-full text-left">
    <thead>
      <tr class="bg-zinc-900/60 border-b border-zinc-800/60">
        <th class="px-6 py-4 text-xs font-semibold text-zinc-500 uppercase tracking-wider">Data</th>
        <th class="px-6 py-4 text-xs font-semibold text-zinc-500 uppercase tracking-wider">Tipo</th>
        <th class="px-6 py-4 text-xs font-semibold text-zinc-500 uppercase tracking-wider text-right">Quantidade</th>
        <th class="px-6 py-4 text-xs font-semibold text-zinc-500 uppercase tracking-wider text-right">Preço (R$)</th>
        <th class="px-6 py-4 text-xs font-semibold text-zinc-500 uppercase tracking-wider text-right">Total (R$)</th>
        <th class="px-6 py-4 text-xs font-semibold text-zinc-500 uppercase tracking-wider text-center">Ações</th>
      </tr>
    </thead>
    <tbody class="divide-y divide-zinc-800/60">
      <% @trades.each do |trade| %>
        <tr class="hover:bg-zinc-800/40 transition-colors">
          <td class="px-6 py-4 text-sm text-zinc-100"><%= l(trade.date, format: :default) %></td>
          <td class="px-6 py-4">
            <span class="text-xs font-semibold <%= trade.trade_type == 'buy' ? 'text-emerald-400' : 'text-red-400' %>">
              <%= trade.trade_type == "buy" ? "Compra" : "Venda" %>
            </span>
          </td>
          <td class="px-6 py-4 text-right text-sm text-zinc-100"><%= trade.quantity.to_i %></td>
          <td class="px-6 py-4 text-right text-sm text-zinc-100"><%= number_to_currency(trade.price / 100.0, unit: "R$ ", separator: ",", delimiter: ".") %></td>
          <td class="px-6 py-4 text-right text-sm text-zinc-100"><%= number_to_currency(trade.quantity * trade.price / 100.0, unit: "R$ ", separator: ",", delimiter: ".") %></td>
          <td class="px-6 py-4 text-center">
            <div class="flex justify-center gap-2">
              <%= link_to edit_dashboard_investment_trade_path(@investment, trade), class: "p-1 text-zinc-500 hover:text-zinc-100 transition-colors" do %>
                <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
              <% end %>
              <%= button_to dashboard_investment_trade_path(@investment, trade), method: :delete,
                  class: "p-1 text-zinc-500 hover:text-red-400 transition-colors",
                  data: { turbo_confirm: "Excluir esta operação?" } do %>
                <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
              <% end %>
            </div>
          </td>
        </tr>
      <% end %>
      <% if @trades.empty? %>
        <tr>
          <td colspan="6" class="px-6 py-12 text-center text-zinc-600 text-sm">
            Nenhuma operação registrada. Adicione compras e vendas acima.
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>
