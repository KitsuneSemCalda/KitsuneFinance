<div class="flex justify-between items-center mb-8">
  <div>
    <h2 class="text-2xl font-bold text-zinc-100">Investimentos</h2>
    <p class="text-zinc-500 text-sm">Acompanhe seu portfólio de ativos.</p>
  </div>
  <div class="flex gap-4">
    <%= link_to new_dashboard_investment_path, class: "bg-indigo-600 hover:bg-indigo-500 text-white font-medium py-2 px-4 rounded-xl transition-all shadow-lg shadow-indigo-500/25 flex items-center gap-2" do %>
      <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path d="M12 4v16m8-8H4" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
      Novo Ativo
    <% end %>
  </div>
</div>

<%# Summary Cards %>
<div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-8">
  <div class="bg-zinc-900/60 border border-zinc-800/60 rounded-2xl p-6">
    <span class="text-xs text-zinc-500 uppercase tracking-wider block mb-1">Valor Total</span>
    <p class="text-3xl font-bold text-zinc-100"><%= number_to_currency(@total_value / 100.0, unit: "R$ ", separator: ",", delimiter: ".") %></p>
  </div>
  <%# Add more summary cards if needed %>
</div>

<div class="bg-zinc-900/40 border border-zinc-800/60 rounded-2xl overflow-hidden backdrop-blur-xl">
  <table class="w-full text-left table-fixed">
    <colgroup>
      <col class="w-[22%]">
      <col class="w-[10%]">
      <col class="w-[8%]">
      <col class="w-[12%]">
      <col class="w-[12%]">
      <col class="w-[12%]">
      <col class="w-[14%]">
      <col class="w-[10%]">
    </colgroup>
    <thead>
      <tr class="bg-zinc-900/60 border-b border-zinc-800/60">
        <th class="px-6 py-4 text-xs font-semibold text-zinc-500 uppercase tracking-wider text-left">Ativo</th>
        <th class="px-4 py-4 text-xs font-semibold text-zinc-500 uppercase tracking-wider text-left">Tipo</th>
        <th class="px-4 py-4 text-xs font-semibold text-zinc-500 uppercase tracking-wider text-right">Qtd</th>
        <th class="px-4 py-4 text-xs font-semibold text-zinc-500 uppercase tracking-wider text-right">P. Médio</th>
        <th class="px-4 py-4 text-xs font-semibold text-zinc-500 uppercase tracking-wider text-right">P. Atual</th>
        <th class="px-4 py-4 text-xs font-semibold text-zinc-500 uppercase tracking-wider text-right">Valor Total</th>
        <th class="px-4 py-4 text-xs font-semibold text-zinc-500 uppercase tracking-wider text-right">Ganho/Perda</th>
        <th class="px-4 py-4 text-xs font-semibold text-zinc-500 uppercase tracking-wider text-center">Ações</th>
      </tr>
    </thead>
    <tbody class="divide-y divide-zinc-800/60">
      <% @investments.each do |inv| %>
        <tr class="hover:bg-zinc-800/40 transition-colors">
          <td class="px-6 py-5">
            <div class="flex items-center gap-3">
              <div class="min-w-0">
                <p class="text-sm font-bold text-zinc-100 truncate"><%= inv.ticker.presence || inv.name %></p>
                <p class="text-xs text-zinc-500 truncate"><%= inv.name %></p>
              </div>
            </div>
          </td>
          <td class="px-4 py-5 whitespace-nowrap">
            <% type_labels = { "stock_br" => "Ação BR", "fii" => "FII", "fixed_income" => "Renda Fixa", "treasury_br" => "Tesouro BR", "treasury_intl" => "Tesouro Intl", "international" => "Internacional", "crypto" => "Cripto", "other" => "Outros" } %>
            <span class="inline-block text-[11px] font-medium text-zinc-500 bg-zinc-800/60 px-2.5 py-1 rounded-full"><%= type_labels[inv.asset_type] || inv.asset_type.humanize %></span>
          </td>
          <td class="px-4 py-5 text-right text-sm text-zinc-100 whitespace-nowrap tabular-nums">
            <%= (inv.quantity || 0).to_i %>
          </td>
          <% has_avg = inv.avg_price > 0 || inv.trades.any? %>
          <% has_price = inv.current_price > 0 %>
          <% estimated_avg = has_avg ? inv.avg_price : (has_price ? inv.current_price : 0) %>
          <% display_avg_price = has_avg ? inv.avg_price : estimated_avg %>
          <% display_gain_loss = (display_avg_price > 0 && has_price) ? (inv.current_value - (inv.quantity * display_avg_price)) : nil %>

          <td class="px-4 py-5 text-right whitespace-nowrap tabular-nums">
            <% if display_avg_price > 0 %>
              <span class="text-sm text-zinc-100"><%= number_to_currency(display_avg_price / 100.0, unit: "R$ ", separator: ",", delimiter: ".") %></span>
              <% unless has_avg %>
                <span class="text-[10px] text-zinc-600 ml-0.5">*</span>
              <% end %>
            <% else %>
              <span class="text-sm text-zinc-600">—</span>
              <%= link_to dashboard_investment_trades_path(inv), class: "ml-1 text-[10px] text-indigo-500 hover:text-indigo-400", title: "Adicionar operações" do %>
                <svg class="w-3 h-3 inline" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path d="M12 4v16m8-8H4" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
              <% end %>
            <% end %>
          </td>
          <td class="px-4 py-5 text-right whitespace-nowrap tabular-nums">
            <% if has_price %>
              <span class="text-sm text-zinc-100"><%= number_to_currency(inv.current_price / 100.0, unit: "R$ ", separator: ",", delimiter: ".") %></span>
            <% else %>
              <span class="text-sm text-zinc-600">—</span>
              <%= button_to refresh_price_dashboard_investment_path(inv), method: :post, class: "ml-1 text-zinc-600 hover:text-sky-400 transition-colors inline", title: "Buscar preço" do %>
                <svg class="w-3 h-3 inline" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
              <% end %>
            <% end %>
          </td>
          <td class="px-4 py-5 text-right text-sm font-bold text-zinc-100 whitespace-nowrap tabular-nums">
            <%= number_to_currency(inv.current_value / 100.0, unit: "R$ ", separator: ",", delimiter: ".") %>
          </td>
          <td class="px-4 py-5 text-right whitespace-nowrap">
            <% if display_gain_loss != nil %>
              <% gain_pct = display_avg_price > 0 ? ((inv.current_value.to_f / (inv.quantity * display_avg_price)) - 1) * 100 : 0 %>
              <div class="<%= display_gain_loss >= 0 ? 'text-emerald-400' : 'text-red-400' %>">
                <p class="text-sm font-bold tabular-nums">
                  <%= number_to_currency(display_gain_loss / 100.0, unit: "R$ ", separator: ",", delimiter: ".") %>
                </p>
                <p class="text-[11px] font-medium <%= display_gain_loss >= 0 ? 'text-emerald-400/70' : 'text-red-400/70' %>">
                  <%= number_to_percentage(gain_pct, precision: 2) %>
                </p>
              </div>
            <% else %>
              <span class="text-xs text-zinc-600">—</span>
            <% end %>
          </td>
          <td class="px-4 py-5 text-center">
            <div class="flex items-center justify-center gap-2">
              <%= button_to refresh_price_dashboard_investment_path(inv), method: :post, class: "p-2 text-zinc-500 hover:text-sky-400 bg-zinc-800/40 hover:bg-zinc-800 rounded-lg transition-all", title: "Atualizar preço" do %>
                <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
              <% end %>
              <%= link_to dashboard_investment_trades_path(inv), class: "p-2 text-zinc-500 hover:text-amber-400 bg-zinc-800/40 hover:bg-zinc-800 rounded-lg transition-all", title: "Operações" do %>
                <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-3 7h3m-3 4h3m-6-4h.01M9 16h.01" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
              <% end %>
              <%= link_to edit_dashboard_investment_path(inv), class: "p-2 text-zinc-500 hover:text-zinc-100 bg-zinc-800/40 hover:bg-zinc-800 rounded-lg transition-all", title: "Editar" do %>
                <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
              <% end %>
              <%= button_to dashboard_investment_path(inv), method: :delete, class: "p-2 text-zinc-500 hover:text-red-400 bg-zinc-800/40 hover:bg-zinc-800 rounded-lg transition-all", title: "Excluir", data: { turbo_confirm: "Tem certeza?" } do %>
                <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
              <% end %>
            </div>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>

  <% truly_missing = @investments.select { |i| i.avg_price.zero? && i.current_price.zero? && i.trades.none? } %>
  <% estimated = @investments.select { |i| i.avg_price.zero? && i.current_price > 0 && i.trades.none? } %>
  <% if truly_missing.any? %>
    <div class="px-6 py-4 border-t border-zinc-800/60 bg-zinc-900/30">
      <div class="flex items-center gap-2 text-xs text-zinc-500">
        <svg class="w-4 h-4 text-amber-400 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
        <span><%= truly_missing.count %> ativo(s) com dados incompletos.</span>
        <span class="text-zinc-600">— Preencha o P. Médio via <strong class="text-zinc-400 font-medium">Operações</strong> ou o P. Atual via <strong class="text-zinc-400 font-medium">botão 🔄</strong>.</span>
      </div>
    </div>
  <% end %>
  <% if estimated.any? %>
    <div class="px-6 py-3 border-t border-zinc-800/60 bg-zinc-900/20">
      <p class="text-xs text-zinc-600"><span class="text-zinc-500 font-medium">*</span> Preço médio estimado com base no preço atual — adicione <strong class="text-zinc-400 font-medium">Operações</strong> de compra para precisão real.</p>
    </div>
  <% end %>
</div>
